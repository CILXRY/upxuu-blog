---
import type { MarkdownHeading } from "astro";

interface Props {
    headings?: MarkdownHeading[];
}

const { headings = [] } = Astro.props;

let minDepth = 10;
for (const h of headings) {
    minDepth = Math.min(minDepth, h.depth);
}

const maxLevel = 3;
let heading1Count = 0;

const removeHash = (text: string) => {
    const i = text.lastIndexOf('#');
    return i === text.length - 1 ? text.substring(0, i) : text;
};
---

<button id="mobile-toc-btn" class="fixed bottom-5 right-5 w-12 h-12 rounded-full bg-[var(--primary)] text-white font-bold text-xs shadow-lg flex items-center justify-center lg:hidden z-[60] active:scale-90 transition-transform">
    <span id="mobile-toc-progress-text">0%</span>
</button>

<div id="mobile-toc-backdrop" class="fixed inset-0 z-[70] hidden opacity-0 transition-opacity duration-300 lg:hidden"></div>

<div id="mobile-toc-panel" class="fixed right-5 z-[80] lg:hidden transition-all duration-300" style="bottom: calc(4.5rem + 4px);">
    <div class="w-64 bg-[var(--card-bg)] border border-[var(--line-color)] rounded-2xl shadow-xl overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 border-b border-[var(--line-color)]">
            <span class="font-bold">目录</span>
            <button id="mobile-toc-close" class="w-7 h-7 rounded-lg flex items-center justify-center hover:bg-[var(--toc-btn-hover)] active:bg-[var(--toc-btn-active)] transition">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </button>
        </div>
        <div class="p-2 max-h-[50vh] overflow-y-auto">
            <div id="mobile-toc-inner">
            {headings.length > 0 ? headings.filter((h) => h.depth < minDepth + maxLevel).map((h) => {
                let badge = '';
                if (h.depth === minDepth) {
                    heading1Count++;
                    badge = `<div class="transition w-5 h-5 shrink-0 rounded-lg text-xs flex items-center justify-center font-bold bg-[var(--toc-badge-bg)] text-[var(--btn-content)]">${heading1Count}</div>`;
                } else if (h.depth === minDepth + 1) {
                    badge = `<div class="ml-4 transition w-5 h-5 shrink-0 rounded-lg text-xs flex items-center justify-center font-bold"><div class="transition w-2 h-2 rounded-[0.1875rem] bg-[var(--toc-badge-bg)]"></div></div>`;
                } else {
                    badge = `<div class="ml-8 transition w-5 h-5 shrink-0 rounded-lg text-xs flex items-center justify-center font-bold"><div class="transition w-1.5 h-1.5 rounded-sm bg-black/5 dark:bg-white/10"></div></div>`;
                }
                const indentClass = h.depth === minDepth || h.depth === minDepth + 1 ? 'text-50' : 'text-30';
                return (
                    <a href={`#${h.slug}`} class="flex items-center gap-2 px-2 py-1.5 rounded-lg transition hover:bg-[var(--toc-btn-hover)] active:bg-[var(--toc-btn-active)]">
                        <div innerHTML={badge}></div>
                        <span class={`text-sm ${indentClass}`}>{removeHash(h.text)}</span>
                    </a>
                );
            }) : <div class="text-center text-sm text-black/50 dark:text-white/50 py-4">暂无目录</div>}
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        const tocBtn = document.getElementById('mobile-toc-btn');
        const tocPanel = document.getElementById('mobile-toc-panel');
        const tocBackdrop = document.getElementById('mobile-toc-backdrop');
        const tocClose = document.getElementById('mobile-toc-close');
        const progressText = document.getElementById('mobile-toc-progress-text');

        if (!tocBtn || !tocPanel || !tocBackdrop) return;

        function openToc() {
            tocPanel.style.transform = 'translateY(0)';
            tocPanel.style.opacity = '1';
            tocBackdrop.classList.remove('hidden');
            setTimeout(() => {
                tocBackdrop.style.opacity = '1';
            }, 10);
        }

        function closeToc() {
            tocPanel.style.transform = 'translateY(10px)';
            tocPanel.style.opacity = '0';
            tocBackdrop.style.opacity = '0';
            setTimeout(() => {
                tocBackdrop.classList.add('hidden');
            }, 300);
        }

        tocBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            if (tocPanel.style.opacity === '1') {
                closeToc();
            } else {
                openToc();
            }
        });

        tocClose?.addEventListener('click', closeToc);
        tocBackdrop?.addEventListener('click', closeToc);

        tocPanel?.addEventListener('click', (e) => {
            if ((e.target as HTMLElement).closest('a[href^="#"]')) {
                setTimeout(closeToc, 150);
            }
        });

        function updateProgress() {
            if (!progressText) return;
            const scrollTop = document.documentElement.scrollTop || document.body.scrollTop;
            const docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const progress = docHeight > 0 ? Math.round((scrollTop / docHeight) * 100) : 0;
            progressText.textContent = progress + '%';
        }

        window.addEventListener('scroll', updateProgress, { passive: true });
        updateProgress();

        window.swup?.hooks?.on('page:view', () => {
            updateProgress();
            closeToc();
        });

        window.addEventListener('popstate', closeToc);

        // Initial state
        tocPanel.style.transform = 'translateY(10px)';
        tocPanel.style.opacity = '0';
    })();
</script>
