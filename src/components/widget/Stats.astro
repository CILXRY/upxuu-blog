---
import WidgetLayout from "./WidgetLayout.astro";
---

<WidgetLayout name="站点统计" isCollapsed={false}>
    <div id="umami-sidebar-stats" class="space-y-2">
        <div class="bg-gray-50 dark:bg-gray-800/60 px-3 py-2 rounded-lg flex items-center justify-between">
            <span class="text-xs text-gray-600 dark:text-gray-400">👁️ 总访问量</span>
            <span id="total-views" class="text-sm font-semibold text-gray-800 dark:text-gray-200">-</span>
        </div>
        <div class="bg-gray-50 dark:bg-gray-800/60 px-3 py-2 rounded-lg flex items-center justify-between">
            <span class="text-xs text-gray-600 dark:text-gray-400">👥 总访问人数</span>
            <span id="total-visitors" class="text-sm font-semibold text-gray-800 dark:text-gray-200">-</span>
        </div>
        <div class="bg-gray-50 dark:bg-gray-800/60 px-3 py-2 rounded-lg flex items-center justify-between">
            <span class="text-xs text-gray-600 dark:text-gray-400">🚀 访问次数</span>
            <span id="total-visits" class="text-sm font-semibold text-gray-800 dark:text-gray-200">-</span>
        </div>
    </div>
</WidgetLayout>

<script>
async function fetchUmamiStats() {
    try {
        const response = await fetch('https://upxuu.com/statsapi/alltime');
        if (!response.ok) throw new Error('Failed to fetch');
        const data = await response.json();
        
        const viewsEl = document.getElementById('total-views');
        const visitorsEl = document.getElementById('total-visitors');
        const visitsEl = document.getElementById('total-visits');
        
        if (viewsEl && data.pageviews) {
            viewsEl.textContent = data.pageviews.toLocaleString('zh-CN');
        }
        if (visitorsEl && data.visitors) {
            visitorsEl.textContent = data.visitors.toLocaleString('zh-CN');
        }
        if (visitsEl && data.visits) {
            visitsEl.textContent = data.visits.toLocaleString('zh-CN');
        }
    } catch (error) {
        console.error('Error fetching umami stats:', error);
    }
}

fetchUmamiStats();
</script>
