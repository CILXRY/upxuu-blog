---
---

<div id="welcome-toast" class="fixed top-20 right-4 z-50 transform -translate-y-full opacity-0 transition-all duration-500 ease-out">
    <div class="bg-gradient-to-r from-blue-50 to-cyan-50 dark:from-blue-900/30 dark:to-cyan-900/30 border border-blue-200 dark:border-blue-700 rounded-lg shadow-lg p-4 max-w-xs">
        <div class="flex items-start gap-3">
            <div class="flex-shrink-0 text-2xl">👋</div>
            <div class="flex-1 min-w-0">
                <p id="welcome-message" class="text-sm font-semibold text-gray-800 dark:text-gray-200">
                    正在加载...
                </p>
                <p id="welcome-stats" class="text-xs text-gray-600 dark:text-gray-400 mt-1">
                    
                </p>
            </div>
            <button 
                onclick="closeWelcomeToast()"
                class="flex-shrink-0 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors"
                aria-label="关闭"
            >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
    </div>
</div>

<script>
    const VISIT_SESSION_KEY = 'blog_visit_flag';
    let hasShownToast = false;
    
    function closeWelcomeToast() {
        const toast = document.getElementById('welcome-toast');
        if (toast) {
            toast.classList.add('translate-y-full', 'opacity-0');
            toast.classList.remove('translate-y-0', 'opacity-100');
            setTimeout(() => {
                toast.style.display = 'none';
            }, 500);
        }
    }
    
    async function fetchLocation() {
        try {
            const response = await fetch('https://v2.xxapi.cn/api/ip');
            const data = await response.json();
            
            if (data.code === 200 && data.data) {
                const location = data.data;
                const locationText = `HI 来自${location.address}的朋友`;
                
                const messageEl = document.getElementById('welcome-message');
                if (messageEl) {
                    messageEl.textContent = locationText;
                }
            }
        } catch (error) {
            console.error('Failed to fetch location:', error);
            const messageEl = document.getElementById('welcome-message');
            if (messageEl) {
                messageEl.textContent = 'HI 来自远方的朋友';
            }
        }
    }
    
    async function fetchStats() {
        try {
            const response = await fetch('https://upxuu.com/statsapi/alltime');
            const data = await response.json();
            
            if (data && data.pageviews !== undefined) {
                const statsText = `欢迎 我是 UpXuu 你是本站迎来的第${data.pageviews}次访问`;
                
                const statsEl = document.getElementById('welcome-stats');
                if (statsEl) {
                    statsEl.textContent = statsText;
                }
            }
        } catch (error) {
            console.error('Failed to fetch stats:', error);
            const statsEl = document.getElementById('welcome-stats');
            if (statsEl) {
                statsEl.textContent = '欢迎 我是 UpXuu';
            }
        }
    }
    
    async function showWelcomeToast() {
        if (hasShownToast) return;
        
        console.log('🎉 开始显示加载动画');
        
        const toast = document.getElementById('welcome-toast');
        if (toast) {
            // 先显示加载动画
            toast.style.display = 'block';
            setTimeout(() => {
                toast.classList.remove('translate-y-full', 'opacity-0');
                toast.classList.add('translate-y-0', 'opacity-100');
            }, 100);
            
            hasShownToast = true;
        }
        
        // 等待数据加载完成
        console.log('📡 正在加载数据...');
        await Promise.all([fetchLocation(), fetchStats()]);
        console.log('✅ 数据加载完成，开始计时 5 秒');
        
        // 数据加载完成后，5 秒后关闭
        setTimeout(() => {
            console.log('⏰ 时间到，关闭弹窗');
            closeWelcomeToast();
        }, 5000);
    }
    
    function shouldShowWelcome() {
        return !sessionStorage.getItem(VISIT_SESSION_KEY);
    }
    
    function markAsVisited() {
        sessionStorage.setItem(VISIT_SESSION_KEY, 'true');
    }
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', async () => {
            if (shouldShowWelcome()) {
                markAsVisited();
                await showWelcomeToast();
            }
        });
    } else {
        if (shouldShowWelcome()) {
            markAsVisited();
            await showWelcomeToast();
        }
    }
    
    (window as any).closeWelcomeToast = closeWelcomeToast;
</script>

<style>
    #welcome-toast {
        max-width: calc(100vw - 2rem);
    }
    
    @media (max-width: 640px) {
        #welcome-toast {
            top: 4rem;
            left: 50%;
            right: auto;
            transform: translateX(-50%) translateY(-100%);
            width: 90%;
            max-width: none;
            transition: transform 0.5s ease-out, opacity 0.5s ease-out;
        }
        
        #welcome-toast.translate-y-0 {
            transform: translateX(-50%) translateY(0);
        }
        
        #welcome-toast .max-w-xs {
            max-width: none;
        }
    }
</style>
