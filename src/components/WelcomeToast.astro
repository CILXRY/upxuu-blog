---
---

<div id="welcome-toast" class="fixed bottom-4 right-4 z-50 transform translate-y-full opacity-0 transition-all duration-500 ease-out">
    <div class="bg-gradient-to-r from-blue-50 to-cyan-50 dark:from-blue-900/30 dark:to-cyan-900/30 border border-blue-200 dark:border-blue-700 rounded-lg shadow-lg p-4 max-w-xs">
        <div class="flex items-start gap-3">
            <div class="flex-shrink-0 text-2xl">👋</div>
            <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-800 dark:text-gray-200">HI~ 欢迎回来~</p>
                <p id="welcome-location" class="text-xs text-gray-600 dark:text-gray-400 mt-1">
                    正在获取位置信息...
                </p>
            </div>
            <button 
                onclick="closeWelcomeToast()"
                class="flex-shrink-0 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors"
                aria-label="关闭"
            >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
    </div>
</div>

<script>
    const VISIT_SESSION_KEY = 'blog_visit_flag';
    let hasShownToast = false;
    
    function closeWelcomeToast() {
        const toast = document.getElementById('welcome-toast');
        if (toast) {
            toast.classList.add('translate-y-full', 'opacity-0');
            toast.classList.remove('translate-y-0', 'opacity-100');
            setTimeout(() => {
                toast.style.display = 'none';
            }, 500);
        }
    }
    
    async function fetchLocation() {
        try {
            const response = await fetch('https://v2.xxapi.cn/api/ip');
            const data = await response.json();
            
            if (data.code === 200 && data.data) {
                const location = data.data;
                const locationText = `来自${location.address}的朋友`;
                
                const locationEl = document.getElementById('welcome-location');
                if (locationEl) {
                    locationEl.textContent = locationText;
                }
            }
        } catch (error) {
            console.error('Failed to fetch location:', error);
            const locationEl = document.getElementById('welcome-location');
            if (locationEl) {
                locationEl.textContent = '来自远方的朋友';
            }
        }
    }
    
    function showWelcomeToast() {
        if (hasShownToast) return;
        
        const toast = document.getElementById('welcome-toast');
        if (toast) {
            toast.style.display = 'block';
            setTimeout(() => {
                toast.classList.remove('translate-y-full', 'opacity-0');
                toast.classList.add('translate-y-0', 'opacity-100');
            }, 100);
            
            hasShownToast = true;
            
            setTimeout(() => {
                closeWelcomeToast();
            }, 5000);
        }
    }
    
    function shouldShowWelcome() {
        return !sessionStorage.getItem(VISIT_SESSION_KEY);
    }
    
    function markAsVisited() {
        sessionStorage.setItem(VISIT_SESSION_KEY, 'true');
    }
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
            if (shouldShowWelcome()) {
                markAsVisited();
                fetchLocation();
                showWelcomeToast();
            }
        });
    } else {
        if (shouldShowWelcome()) {
            markAsVisited();
            fetchLocation();
            showWelcomeToast();
        }
    }
    
    (window as any).closeWelcomeToast = closeWelcomeToast;
</script>

<style>
    #welcome-toast {
        max-width: calc(100vw - 2rem);
    }
    
    @media (max-width: 640px) {
        #welcome-toast {
            bottom: 0;
            left: 50%;
            right: auto;
            transform: translateX(-50%) translateY(100%);
            width: 90%;
            max-width: none;
            transition: transform 0.5s ease-out, opacity 0.5s ease-out;
        }
        
        #welcome-toast.translate-y-0 {
            transform: translateX(-50%) translateY(0);
        }
        
        #welcome-toast .max-w-xs {
            max-width: none;
        }
    }
</style>
