---

import { profileConfig } from "../config";
import { url } from "../utils/url-utils";
import { getLatestCommit, formatRelativeTime } from "../utils/git-info";

const currentYear = new Date().getFullYear();
const commitInfo = await getLatestCommit();
---

<!--<div class="border-t border-[var(&#45;&#45;primary)] mx-16 border-dashed py-8 max-w-[var(&#45;&#45;page-width)] flex flex-col items-center justify-center px-6">-->
<div class="transition border-t border-black/10 dark:border-white/15 my-10 border-dashed mx-32"></div>
<!--<div class="transition bg-[oklch(92%_0.01_var(&#45;&#45;hue))] dark:bg-black rounded-2xl py-8 mt-4 mb-8 flex flex-col items-center justify-center px-6">-->
<div class="transition border-dashed border-[oklch(85%_0.01_var(--hue))] dark:border-white/15 rounded-2xl mb-12 bg-gray-50/80 dark:bg-gray-800/50 flex flex-col items-center justify-center px-6 py-8">
    <div class="transition text-sm text-center text-gray-700 dark:text-gray-300">
        &copy; <span id="copyright-year">{currentYear}</span> {profileConfig.name}. All Rights Reserved. /
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href={url('rss.xml')}>RSS</a> /
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href={url('sitemap-index.xml')}>Sitemap</a><br>
        Powered by
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href="https://astro.build">Astro</a> &
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href="https://github.com/saicaca/fuwari">Fuwari</a><br>
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href="https://icp.gov.moe/?keyword=20269996">萌 ICP 备 20269996 号</a>
        {commitInfo && (
            <div class="mt-3 flex flex-col items-center gap-1.5 text-xs">
                <a 
                    href={`https://github.com/ImUpXuu/myblog/commit/${commitInfo.sha}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 text-gray-600 dark:text-gray-400 hover:text-[var(--primary)] transition-colors"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                    </svg>
                    <span class="font-medium">Latest commit:</span>
                    <code class="bg-gray-200 dark:bg-gray-700 px-2 py-0.5 rounded text-xs font-mono">{commitInfo.shortSha}</code>
                    <span class="text-gray-400">·</span>
                    <span>{formatRelativeTime(commitInfo.date)}</span>
                </a>
                <p class="text-gray-500 dark:text-gray-500 text-xs max-w-md truncate px-4">
                    {commitInfo.message}
                </p>
            </div>
        )}
    </div>
</div>