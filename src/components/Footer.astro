---

import { profileConfig } from "../config";
import { url } from "../utils/url-utils";

const currentYear = new Date().getFullYear();
---

<div id="footer-commit-info" class="hidden"></div>

<!--<div class="border-t border-[var(&#45;&#45;primary)] mx-16 border-dashed py-8 max-w-[var(&#45;&#45;page-width)] flex flex-col items-center justify-center px-6">-->
<div class="transition border-t border-black/10 dark:border-white/15 my-10 border-dashed mx-32"></div>
<!--<div class="transition bg-[oklch(92%_0.01_var(&#45;&#45;hue))] dark:bg-black rounded-2xl py-8 mt-4 mb-8 flex flex-col items-center justify-center px-6">-->
<div class="transition border-dashed border-[oklch(85%_0.01_var(--hue))] dark:border-white/15 rounded-2xl mb-12 bg-gray-50/80 dark:bg-gray-800/50 flex flex-col items-center justify-center px-6 py-8">
    <div class="transition text-sm text-center text-gray-700 dark:text-gray-300">
        &copy; <span id="copyright-year">{currentYear}</span> {profileConfig.name}. All Rights Reserved. /
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href={url('rss.xml')}>RSS</a> /
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href={url('sitemap-index.xml')}>Sitemap</a><br>
        Powered by
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href="https://astro.build">Astro</a> &
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href="https://github.com/saicaca/fuwari">Fuwari</a><br>
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href="https://icp.gov.moe/?keyword=20269996">萌 ICP 备 20269996 号</a>
        <div id="commit-info-container" class="mt-3 flex flex-col items-center gap-1.5 text-xs px-4">
            <div class="flex flex-wrap items-center justify-center gap-2 text-gray-600 dark:text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                </svg>
                <span class="font-medium">Latest commit:</span>
                <a 
                    id="commit-sha-link"
                    href="#"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[var(--primary)] hover:underline font-mono"
                >
                    <span id="commit-sha">加载中...</span>
                </a>
                <span class="text-gray-400">·</span>
                <span>最后更新于</span>
                <span id="commit-date">加载中...</span>
                <span class="text-gray-400">·</span>
                <a 
                    href="/diff"
                    class="text-[var(--primary)] hover:underline"
                >
                    更新日志
                </a>
            </div>
            <p class="text-gray-500 dark:text-gray-500 text-xs text-center break-words w-full">
                更新内容：<span id="commit-message">加载中...</span>
            </p>
        </div>
    </div>
</div>

<script>
    async function fetchCommitInfo() {
        try {
            const response = await fetch('https://api.github.com/repos/ImUpXuu/myblog/commits?per_page=1', {
                headers: {
                    'Accept': 'application/vnd.github.v3+json',
                },
            });

            if (!response.ok) {
                throw new Error('Failed to fetch commit info');
            }

            const commits = await response.json();
            if (commits && commits.length > 0) {
                const commit = commits[0];
                const sha = commit.sha;
                const shortSha = sha.substring(0, 7);
                const dateStr = commit.commit.author.date;
                const message = commit.commit.message;
                
                // 格式化日期（北京时间 +8h）
                const date = new Date(dateStr);
                date.setHours(date.getHours() + 8);
                const year = date.getFullYear();
                const month = String(date.getMonth() + 1).padStart(2, '0');
                const day = String(date.getDate()).padStart(2, '0');
                const hour = String(date.getHours()).padStart(2, '0');
                const minute = String(date.getMinutes()).padStart(2, '0');
                const formattedDate = `${year}-${month}-${day} ${hour}:${minute}`;
                
                // 更新 DOM
                const shaLink = document.getElementById('commit-sha-link');
                const shaSpan = document.getElementById('commit-sha');
                const dateSpan = document.getElementById('commit-date');
                const messageSpan = document.getElementById('commit-message');
                
                if (shaLink) shaLink.href = `https://github.com/ImUpXuu/myblog/commit/${sha}`;
                if (shaSpan) shaSpan.textContent = shortSha;
                if (dateSpan) dateSpan.textContent = formattedDate;
                if (messageSpan) messageSpan.textContent = message;
            }
        } catch (error) {
            console.error('Error fetching commit info:', error);
            const shaSpan = document.getElementById('commit-sha');
            const dateSpan = document.getElementById('commit-date');
            const messageSpan = document.getElementById('commit-message');
            
            if (shaSpan) shaSpan.textContent = '获取失败';
            if (dateSpan) dateSpan.textContent = '获取失败';
            if (messageSpan) messageSpan.textContent = '获取失败';
        }
    }
    
    // 页面加载时获取一次
    fetchCommitInfo();
    
    // Swup 页面切换后重新获取
    document.addEventListener('swup:content-replaced', fetchCommitInfo);
</script>