---

import { profileConfig } from "../config";
import { url } from "../utils/url-utils";
import { getLatestCommit, formatRelativeTime } from "../utils/git-info";

const currentYear = new Date().getFullYear();
const commitInfo = await getLatestCommit();
---

<!--<div class="border-t border-[var(&#45;&#45;primary)] mx-16 border-dashed py-8 max-w-[var(&#45;&#45;page-width)] flex flex-col items-center justify-center px-6">-->
<div class="transition border-t border-black/10 dark:border-white/15 my-10 border-dashed mx-32"></div>
<!--<div class="transition bg-[oklch(92%_0.01_var(&#45;&#45;hue))] dark:bg-black rounded-2xl py-8 mt-4 mb-8 flex flex-col items-center justify-center px-6">-->
<div class="transition border-dashed border-[oklch(85%_0.01_var(--hue))] dark:border-white/15 rounded-2xl mb-12 flex flex-col items-center justify-center px-6">
    <div class="transition text-50 text-sm text-center">
        &copy; <span id="copyright-year">{currentYear}</span> {profileConfig.name}. All Rights Reserved. /
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href={url('rss.xml')}>RSS</a> /
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href={url('sitemap-index.xml')}>Sitemap</a><br>
        Powered by
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href="https://astro.build">Astro</a> &
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href="https://github.com/saicaca/fuwari">Fuwari</a><br>
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href="https://icp.gov.moe/?keyword=20269996">萌 ICP 备 20269996 号</a>
        {commitInfo && (
            <div class="mt-2 flex justify-center items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
                <a 
                    href={`https://github.com/ImUpXuu/myblog/commit/${commitInfo.sha}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-1.5 hover:text-[var(--primary)] transition-colors"
                    title={commitInfo.message}
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                    </svg>
                    <span>Latest commit <code class="bg-gray-200 dark:bg-gray-700 px-1.5 py-0.5 rounded text-xs font-mono">{commitInfo.shortSha}</code></span>
                    <span>·</span>
                    <span>{formatRelativeTime(commitInfo.date)}</span>
                </a>
            </div>
        )}
        <div id="umami-stats" class="mt-3 flex justify-center gap-6 text-sm">
            <div class="bg-gray-50 dark:bg-gray-800/60 px-4 py-2 rounded-lg">
                <span class="text-gray-600 dark:text-gray-400">👁️ 总访问量：</span>
                <span id="total-views" class="font-semibold text-gray-800 dark:text-gray-200">-</span>
            </div>
            <div class="bg-gray-50 dark:bg-gray-800/60 px-4 py-2 rounded-lg">
                <span class="text-gray-600 dark:text-gray-400">👥 总访问人数：</span>
                <span id="total-visitors" class="font-semibold text-gray-800 dark:text-gray-200">-</span>
            </div>
            <div class="bg-gray-50 dark:bg-gray-800/60 px-4 py-2 rounded-lg">
                <span class="text-gray-600 dark:text-gray-400">🚀 访问次数：</span>
                <span id="total-visits" class="font-semibold text-gray-800 dark:text-gray-200">-</span>
            </div>
        </div>
    </div>
</div>

<script>
async function fetchUmamiStats() {
    try {
        const response = await fetch('https://upxuu.com/statsapi/alltime');
        if (!response.ok) throw new Error('Failed to fetch');
        const data = await response.json();
        
        const viewsEl = document.getElementById('total-views');
        const visitorsEl = document.getElementById('total-visitors');
        const visitsEl = document.getElementById('total-visits');
        
        if (viewsEl && data.pageviews) {
            viewsEl.textContent = data.pageviews.toLocaleString('zh-CN');
        }
        if (visitorsEl && data.visitors) {
            visitorsEl.textContent = data.visitors.toLocaleString('zh-CN');
        }
        if (visitsEl && data.visits) {
            visitsEl.textContent = data.visits.toLocaleString('zh-CN');
        }
    } catch (error) {
        console.error('Error fetching umami stats:', error);
    }
}

fetchUmamiStats();
</script>