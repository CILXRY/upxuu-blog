---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import BannerTitle from "../components/BannerTitle.astro";
import { profileConfig, siteConfig } from "../config";
import friendsData from "../../public/data/friends.json";

// 添加自己的信息到首位
const friends = [
	{
		name: "UpXuu",
		avatar: "https://upxuu.com/images/20260214145619.jpg",
		url: "https://upxuu.com",
		description: "逐光而上"
	},
	...friendsData
];

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	"@id": `${Astro.site}friends`,
	name: "友情链接",
	description: "UpXuu 的友情链接",
	url: `${Astro.site}friends`,
	author: {
		"@type": "Person",
		name: profileConfig.name,
	},
	inLanguage: siteConfig.lang.replace("_", "-"),
};
---

<MainGridLayout title="友情链接" description="UpXuu 的友情链接">
	<BannerTitle slot="banner-title"></BannerTitle>
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
	<script slot="head" src="https://unpkg.com/@waline/client@v3/dist/waline.js" type="module"></script>
	<link rel="stylesheet" href="https://unpkg.com/@waline/client@v3/dist/waline.css" />
	
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
			<div class="mb-10 text-center">
				<h1 class="text-4xl font-bold text-gray-800 dark:text-gray-200 mb-3">
					🤝 友情链接
				</h1>
			</div>

			<div class="bg-blue-50 dark:bg-blue-900/20 rounded-xl p-4 mb-8 border border-blue-200 dark:border-blue-800">
				<h2 class="text-lg font-semibold text-blue-800 dark:text-blue-300 mb-2">📝 自助申请友链</h2>
				<p class="text-sm text-blue-700 dark:text-blue-400 mb-3">点击下方链接自助申请友链</p>
				<a
					href="https://github.com/ImUpXuu/myblog/issues/new?template=friend-request.yml"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors"
				>
					<span>🆕 新建友链申请</span>
				</a>
			</div>
			
			<div class="friends-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
				{friends.map((friend) => (
					<a
						href={friend.url}
						target="_blank"
						rel="noopener noreferrer"
						class="friend-card block"
					>
						<div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4 transition-all duration-200 hover:shadow-lg hover:bg-gray-100 dark:hover:bg-gray-800">
							<div class="flex items-center gap-3">
								<img
									src={friend.avatar || 'data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"%3E%3Crect fill="%23e5e7eb" width="100" height="100"/%3E%3Ctext x="50" y="55" text-anchor="middle" font-size="40" fill="%239ca3af"%3E?%3C/text%3E%3C/svg%3E'}
									alt={friend.name}
									class="w-12 h-12 rounded-full object-cover flex-shrink-0"
									loading="lazy"
								/>
								<div class="flex-1 min-w-0">
									<h3 class="text-base font-semibold text-gray-800 dark:text-gray-200 truncate">
										{friend.name}
									</h3>
									<p class="text-xs text-gray-500 dark:text-gray-400 truncate mt-0.5">
										{friend.description || '暂无描述'}
									</p>
								</div>
							</div>
						</div>
					</a>
				))}
			</div>
			
			<div class="mt-10 pt-10 border-t border-gray-200 dark:border-gray-700">
				<h2 class="text-2xl font-bold text-gray-800 dark:text-gray-200 mb-6">
					💬 评论
				</h2>
				<div id="waline"></div>
			</div>
		</div>
	</div>
</MainGridLayout>

<script>
import { init } from 'https://unpkg.com/@waline/client@v3/dist/waline.js';

init({
    el: '#waline',
    serverURL: 'https://com2.upxuu.com/',
    path: '/friends/',
    lang: 'zh-CN',
    dark: 'html.dark',
});
</script>

<style>
.friends-grid {
	animation: fadeIn 0.5s ease-out;
}

.friend-card {
	text-decoration: none;
	color: inherit;
}

.friend-card .bg-gray-50 {
	transition: all 0.2s ease;
}

@keyframes fadeIn {
	from {
		opacity: 0;
		transform: translateY(10px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}
</style>
