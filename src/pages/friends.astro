	},
	{
		name: "LsAng",
		url: "https://llds.cloud",
		avatar: "https://llds.cloud/lsang.png",
		description: "学习、探索中",
	},
	{
		name: "流欺の个人博客",
		url: "https://blog.lqay.cn/",
		avatar: "https://tc.lqay.cn/LightPicture/2026/03/5f64e0f0f361e19c.png",
		description: "嗯对就是个博客"
	},
	{
		name: "zplb の博客",
		url: "https://blog.zplb.top",
		avatar: "https://zplb.org.cn/images/zplb.png",
		description: "一个喜欢网安的学生~"
	},
	{
		name: "石猫博客~",
		url: "https://imshimao.com",
		avatar: "",
		description: ""
	},
	{
		name: "巳忆笔记",
		url: "https://lleft.cn/",
		avatar: "https://tc.lleft.cn/PicGo/logo.png",
		description: "记住所有美好回忆"
	},
	{
		name: "zeroanon",
		url: "https://zeroanon.com",
		avatar: "https://avatars.githubusercontent.com/u/119206123?v=4",
		description: "不做圣经里腐朽的诗集，要做禁书里最惊世骇俗的篇章"
	},
	{
		name: "NGC7293的星域",
		url: "https://xmk.life/",
		avatar: "https://xmk.life/ngc7293.png",
		description: "博客"
	},
	{
		name: "瓶中虾",
		url: "https://weiyu14.top",
		avatar: "https://weiyu14.top/assets/ava-e842524e.jpg",
		description: "只闻花香 不争朝夕"
	},
	{
		name: "ChenServer",
		url: "https://etaris.moe",
		avatar: "https://cn.cravatar.com/avatar/f9ff0db2d48c61f21a01f31de18643c2?d=mp&s=240",
		description: "🤔"
	},
	{
		name: "沐光橙香",
		url: "https://mugcx.com",
		avatar: "https://mugcx.com/logo.png",
		description: "暖阳旧时光，草木亦生香"
	},
	{
		name: "无大人生",
		url: "https://blog.wudarensheng.top/",
		avatar: "https://q2.qlogo.cn/headimg_dl?dst_uin=3574552394&spec=0",
		description: "远赴人间惊鸿宴，一睹人间盛世颜。"
	},
	{
		name: "ziworld",
		url: "https://blog.ziworld.top",
		avatar: "https://blog.ziworld.top/assect/images/avatar.webp",
		description: "For all time, always."
	},
	{
		name: "爱琉璃",
		url: "https://www.illlt.com/",
		avatar: "",
		description: ""
	},
	{
		name: "桃花源 TYC",
		url: "https://www.ty2c.com/",
		avatar: "",
		description: ""
	},
	// 在这里添加更多友链...
];

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	"@id": `${Astro.site}friends`,
	name: "友情链接",
	description: "UpXuu 的友情链接",
	url: `${Astro.site}friends`,
	author: {
		"@type": "Person",
		name: profileConfig.name,
	},
	inLanguage: siteConfig.lang.replace("_", "-"),
};
---

<MainGridLayout title="友情链接" description="UpXuu 的友情链接">
	<BannerTitle slot="banner-title"></BannerTitle>
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
	<script slot="head" src="https://comment.upxuu.com/sdk.js" defer></script>
	
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
			<div class="mb-10 text-center">
				<h1 class="text-4xl font-bold text-gray-800 dark:text-gray-200 mb-3">
					🤝 友情链接
				</h1>
			</div>
			
			<div class="friends-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
				{friends.map((friend) => (
					<a
						href={friend.url}
						target="_blank"
						rel="noopener noreferrer"
						class="friend-card block"
					>
						<div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4 transition-all duration-200 hover:shadow-lg hover:bg-gray-100 dark:hover:bg-gray-800">
							<div class="flex items-center gap-3">
								<img
									src={friend.avatar || 'data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"%3E%3Crect fill="%23e5e7eb" width="100" height="100"/%3E%3Ctext x="50" y="55" text-anchor="middle" font-size="40" fill="%239ca3af"%3E?%3C/text%3E%3C/svg%3E'}
									alt={friend.name}
									class="w-12 h-12 rounded-full object-cover flex-shrink-0"
									loading="lazy"
								/>
								<div class="flex-1 min-w-0">
									<h3 class="text-base font-semibold text-gray-800 dark:text-gray-200 truncate">
										{friend.name}
									</h3>
									<p class="text-xs text-gray-500 dark:text-gray-400 truncate mt-0.5">
										{friend.description || '暂无描述'}
									</p>
								</div>
							</div>
						</div>
					</a>
				))}
			</div>
			
			<div class="mt-10 pt-10 border-t border-gray-200 dark:border-gray-700">
				<h2 class="text-2xl font-bold text-gray-800 dark:text-gray-200 mb-6">
					💬 申请友链
				</h2>
				<div id="extalk-comments"></div>
			</div>
		</div>
	</div>
</MainGridLayout>

<style>
.friends-grid {
	animation: fadeIn 0.5s ease-out;
}

.friend-card {
	text-decoration: none;
	color: inherit;
}

.friend-card .bg-gray-50 {
	transition: all 0.2s ease;
}

@keyframes fadeIn {
	from {
		opacity: 0;
		transform: translateY(10px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}
</style>
