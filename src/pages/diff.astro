---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import BannerTitle from "../components/BannerTitle.astro";
import { profileConfig, siteConfig } from "../config";

interface CommitFile {
	filename: string;
	additions: number;
	deletions: number;
	changes: number;
	status: string;
}

interface Commit {
	sha: string;
	shortSha: string;
	date: string;
	message: string;
	author: string;
	files?: CommitFile[];
}

interface DayGroup {
	date: string;
	commits: Commit[];
}

interface MonthGroup {
	year: number;
	month: number;
	days: DayGroup[];
}

async function getAllCommits(): Promise<Commit[]> {
	const allCommits: Commit[] = [];
	let page = 1;
	const perPage = 100;

	try {
		while (true) {
			const response = await fetch(`https://api.github.com/repos/ImUpXuu/myblog/commits?per_page=${perPage}&page=${page}`, {
				headers: {
					'Accept': 'application/vnd.github.v3+json',
				},
				next: { revalidate: 300 }
			});

			if (!response.ok) {
				break;
			}

			const commits = await response.json();
			if (commits.length === 0) {
				break;
			}

			allCommits.push(...commits.map((commit: any) => ({
				sha: commit.sha,
				shortSha: commit.sha.substring(0, 7),
				date: commit.commit.author.date,
				message: commit.commit.message,
				author: commit.commit.author.name,
				files: []
			})));

			page++;
		}

		// 获取每个 commit 的文件变更
		for (let i = 0; i < allCommits.length; i++) {
			try {
				const detailResponse = await fetch(
					`https://api.github.com/repos/ImUpXuu/myblog/commits/${allCommits[i].sha}`,
					{
						headers: {
							'Accept': 'application/vnd.github.v3+json',
						},
						next: { revalidate: 300 }
					}
				);

				if (detailResponse.ok) {
					const detail = await detailResponse.json();
					allCommits[i].files = detail.files?.map((file: any) => ({
						filename: file.filename,
						additions: file.additions,
						deletions: file.deletions,
						changes: file.changes,
						status: file.status
					})) || [];
				}
			} catch (error) {
				console.error(`Failed to fetch files for commit ${allCommits[i].shortSha}:`, error);
			}
		}

	} catch (error) {
		console.error('Error fetching commit history:', error);
	}

	return allCommits;
}

function formatDate(dateString: string): string {
	const date = new Date(dateString);
	date.setHours(date.getHours() + 8);
	const year = date.getFullYear();
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	const hour = String(date.getHours()).padStart(2, '0');
	const minute = String(date.getMinutes()).padStart(2, '0');
	
	return `${year}-${month}-${day} ${hour}:${minute}`;
}

function getRelativeTime(dateString: string): string {
	const date = new Date(dateString);
	date.setHours(date.getHours() + 8);
	const now = new Date();
	const diffInMs = now.getTime() - date.getTime();
	const diffInDays = Math.floor(diffInMs / (1000 * 60 * 60 * 24));

	if (diffInDays === 0) return '今天';
	if (diffInDays === 1) return '昨天';
	if (diffInDays < 7) return `${diffInDays}天前`;
	if (diffInDays < 30) return `${Math.floor(diffInDays / 7)}周前`;
	if (diffInDays < 365) return `${Math.floor(diffInDays / 30)}月前`;
	return `${Math.floor(diffInDays / 365)}年前`;
}

function groupCommitsByMonth(commits: Commit[]): MonthGroup[] {
	const monthMap = new Map<string, MonthGroup>();

	commits.forEach(commit => {
		const date = new Date(commit.date);
		date.setHours(date.getHours() + 8);
		const year = date.getFullYear();
		const month = date.getMonth() + 1;
		const day = date.getDate();
		const dayKey = `${year}-${month}-${day}`;
		const monthKey = `${year}-${month}`;

		if (!monthMap.has(monthKey)) {
			monthMap.set(monthKey, {
				year,
				month,
				days: []
			});
		}

		const monthGroup = monthMap.get(monthKey)!;
		let dayGroup = monthGroup.days.find(d => d.date === dayKey);

		if (!dayGroup) {
			dayGroup = { date: dayKey, commits: [] };
			monthGroup.days.push(dayGroup);
		}

		dayGroup.commits.push(commit);
	});

	return Array.from(monthMap.values()).sort((a, b) => {
		return new Date(b.year, b.month - 1).getTime() - new Date(a.year, a.month - 1).getTime();
	});
}

const allCommits = await getAllCommits();
const groupedCommits = groupCommitsByMonth(allCommits);

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	"@id": `${Astro.site}diff`,
	name: "更新日志",
	description: "UpXuu 博客的更新历史记录",
	url: `${Astro.site}diff`,
	author: {
		"@type": "Person",
		name: profileConfig.name,
	},
	inLanguage: siteConfig.lang.replace("_", "-"),
};
---

<MainGridLayout title="更新日志" description="UpXuu 博客的更新历史记录">
	<BannerTitle slot="banner-title"></BannerTitle>
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
	
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
			<div class="mb-10 text-center">
				<h1 class="text-4xl font-bold text-gray-800 dark:text-gray-200 mb-3">
					📝 更新日志
				</h1>
				<p class="text-gray-600 dark:text-gray-400">
					记录博客的每一次更新与改进
				</p>
				<p class="text-sm text-gray-500 dark:text-gray-500 mt-2">
					共 {allCommits.length} 次提交
				</p>
			</div>
			
			<div class="commit-timeline relative">
				{groupedCommits.map((monthGroup) => (
					<div class="month-section mb-12">
						<div class="sticky top-0 z-20 bg-gradient-to-r from-blue-50 to-cyan-50 dark:from-gray-800 dark:to-gray-800 py-3 -mx-4 px-4 mb-6 rounded-lg border-l-4 border-blue-500">
							<h2 class="text-2xl font-bold text-gray-800 dark:text-gray-200">
								{monthGroup.year}年 {monthGroup.month}月
							</h2>
							<p class="text-sm text-gray-600 dark:text-gray-400">
								{monthGroup.days.reduce((sum, day) => sum + day.commits.length, 0)} 次提交
							</p>
						</div>
						
						<div class="space-y-6">
							{monthGroup.days.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()).map((dayGroup, dayIndex) => (
								<div class="day-group">
									<button 
										class="day-header w-full flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-800/50 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
										onclick={`toggleDay('day-${dayGroup.date.replace(/-/g, '')}')`}
									>
										<div class="flex items-center gap-3">
											<span class="text-lg font-semibold text-gray-700 dark:text-gray-300">
												{dayGroup.date}
											</span>
											<span class="text-sm text-gray-500 dark:text-gray-400">
												{getRelativeTime(dayGroup.date + 'T00:00:00')}
											</span>
										</div>
										<div class="flex items-center gap-3">
											<span class="text-xs bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-400 px-2 py-1 rounded-full">
												{dayGroup.commits.length} 次提交
											</span>
											<svg class="w-5 h-5 text-gray-500 transform transition-transform" id="arrow-day-${dayGroup.date.replace(/-/g, '')}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
											</svg>
										</div>
									</button>
									
									<div class="day-content mt-3 space-y-3" id="day-${dayGroup.date.replace(/-/g, '')}">
										{dayGroup.commits.map((commit, commitIndex) => (
											<div class="commit-item relative pl-8">
												<div class="absolute left-3 top-0 bottom-0 w-0.5 bg-gradient-to-b from-blue-300 to-blue-100 dark:from-blue-700 dark:to-blue-900"></div>
												<div class="absolute left-0 top-2 w-6 h-6 rounded-full bg-blue-500 border-4 border-white dark:border-gray-800 shadow-md"></div>
												
												<div class="bg-white dark:bg-gray-800/50 rounded-lg p-4 shadow-sm hover:shadow-md transition-shadow">
													<div class="flex flex-col gap-3">
														<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2">
															<div class="flex items-center gap-2 flex-wrap">
																<a 
																	href={`https://github.com/ImUpXuu/myblog/commit/${commit.sha}`}
																	target="_blank"
																	rel="noopener noreferrer"
																	class="text-sm font-mono text-blue-600 dark:text-blue-400 hover:underline"
																>
																	{commit.shortSha}
																</a>
																<span class="text-xs text-gray-500 dark:text-gray-400">
																	{formatDate(commit.date)}
																</span>
															</div>
															<span class="text-xs text-gray-500 dark:text-gray-400">
																by {commit.author}
															</span>
														</div>
														
														<p class="text-gray-700 dark:text-gray-300 text-sm font-medium">
															{commit.message}
														</p>
														
														{commit.files && commit.files.length > 0 && (
															<div class="mt-2 pt-2 border-t border-gray-200 dark:border-gray-700">
																<div class="flex flex-wrap gap-2">
																	{commit.files.map((file, fileIndex) => (
																		<span class="inline-flex items-center gap-1 text-xs px-2 py-1 rounded bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400">
																			{file.status === 'added' && <span class="text-green-600 dark:text-green-400">+</span>}
																			{file.status === 'removed' && <span class="text-red-600 dark:text-red-400">-</span>}
																			{file.status === 'modified' && <span class="text-blue-600 dark:text-blue-400">~</span>}
																			{file.filename}
																			{file.changes > 0 && (
																				<span class="text-gray-400">({file.additions} +{file.deletions} -)</span>
																			)}
																		</span>
																	))}
																</div>
															</div>
														)}
													</div>
												</div>
											</div>
										))}
									</div>
								</div>
							))}
						</div>
					</div>
				))}
			</div>
			
			{allCommits.length === 0 && (
				<div class="text-center py-12">
					<p class="text-gray-500 dark:text-gray-400">
						暂无更新记录
					</p>
				</div>
			)}
		</div>
	</div>
	
	<script>
		function toggleDay(dayId: string) {
			const content = document.getElementById(dayId);
			const arrow = document.getElementById('arrow-' + dayId);
			const header = content?.previousElementSibling as HTMLElement;
			
			if (content && arrow) {
				const isExpanded = content.style.display !== 'none';
				
				if (isExpanded) {
					content.style.display = 'none';
					arrow.classList.add('rotate-180');
					header?.classList.add('opacity-60');
				} else {
					content.style.display = 'block';
					arrow.classList.remove('rotate-180');
					header?.classList.remove('opacity-60');
				}
			}
		}
		
		document.addEventListener('DOMContentLoaded', () => {
			const allDays = document.querySelectorAll('.day-content');
			allDays.forEach((day, index) => {
				if (index > 0) {
					const dayId = day.id;
					const arrow = document.getElementById('arrow-' + dayId);
					const header = day.previousElementSibling as HTMLElement;
					
					if (arrow && header) {
						day.style.display = 'none';
						arrow.classList.add('rotate-180');
						header.classList.add('opacity-60');
					}
				}
			});
		});
	</script>
</MainGridLayout>

<style>
.commit-timeline {
	animation: fadeIn 0.5s ease-out;
}

.day-header {
	transition: all 0.2s ease;
}

.day-header:hover {
	transform: translateX(4px);
}

.rotate-180 {
	transform: rotate(-180deg);
}

.month-section {
	scroll-margin-top: 2rem;
}

@keyframes fadeIn {
	from {
		opacity: 0;
		transform: translateY(10px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}
</style>
