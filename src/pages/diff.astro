---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import BannerTitle from "../components/BannerTitle.astro";
import { profileConfig, siteConfig } from "../config";

interface CommitFile {
	filename: string;
	status: 'added' | 'removed' | 'modified' | 'renamed';
	additions: number;
	deletions: number;
}

interface Commit {
	sha: string;
	shortSha: string;
	date: string;
	message: string;
	author: string;
	files: CommitFile[];
}

interface DateGroup {
	date: string;
	formattedDate: string;
	commits: Commit[];
}

interface MonthGroup {
	year: number;
	month: number;
	formattedMonth: string;
	dates: DateGroup[];
}

async function getCommitHistory(): Promise<Commit[]> {
	try {
		const response = await fetch('https://api.github.com/repos/ImUpXuu/myblog/commits?per_page=100', {
			headers: {
				'Accept': 'application/vnd.github.v3+json',
			},
			next: { revalidate: 300 }
		});

		if (!response.ok) {
			throw new Error('Failed to fetch commit history');
		}

		const commits = await response.json();
		
		const commitsWithFiles = await Promise.all(commits.map(async (commit: any) => {
			try {
				const detailResponse = await fetch(commit.url, {
					headers: {
						'Accept': 'application/vnd.github.v3+json',
					},
				});
				
				if (detailResponse.ok) {
					const detail = await detailResponse.json();
					return {
						sha: commit.sha,
						shortSha: commit.sha.substring(0, 7),
						date: commit.commit.author.date,
						message: commit.commit.message,
						author: commit.commit.author.name,
						files: detail.files?.map((file: any) => ({
							filename: file.filename,
							status: file.status,
							additions: file.additions,
							deletions: file.deletions
						})) || []
					};
				}
			} catch (error) {
				console.error('Failed to fetch files for commit:', commit.sha);
			}
			
			return {
				sha: commit.sha,
				shortSha: commit.sha.substring(0, 7),
				date: commit.commit.author.date,
				message: commit.commit.message,
				author: commit.commit.author.name,
				files: []
			};
		}));
		
		return commitsWithFiles;
	} catch (error) {
		console.error('Error fetching commit history:', error);
		return [];
	}
}

function formatDate(dateString: string): string {
	const date = new Date(dateString);
	date.setHours(date.getHours() + 8);
	const year = date.getFullYear();
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	const hour = String(date.getHours()).padStart(2, '0');
	const minute = String(date.getMinutes()).padStart(2, '0');
	
	return `${year}-${month}-${day} ${hour}:${minute}`;
}

function formatDisplayDate(dateString: string): string {
	const date = new Date(dateString);
	date.setHours(date.getHours() + 8);
	const year = date.getFullYear();
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	
	return `${year}-${month}-${day}`;
}

function formatMonth(year: number, month: number): string {
	return `${year}年${month}月`;
}

function groupCommitsByDate(commits: Commit[]): DateGroup[] {
	const groups = new Map<string, Commit[]>();
	
	commits.forEach(commit => {
		const dateKey = formatDisplayDate(commit.date);
		if (!groups.has(dateKey)) {
			groups.set(dateKey, []);
		}
		groups.get(dateKey)!.push(commit);
	});
	
	return Array.from(groups.entries()).map(([date, commits]) => ({
		date,
		formattedDate: date,
		commits
	}));
}

function groupByMonth(dateGroups: DateGroup[]): MonthGroup[] {
	const months = new Map<string, MonthGroup>();
	
	dateGroups.forEach(dateGroup => {
		const [year, month] = dateGroup.date.split('-').map(Number);
		const monthKey = `${year}-${month}`;
		
		if (!months.has(monthKey)) {
			months.set(monthKey, {
				year,
				month,
				formattedMonth: formatMonth(year, month),
				dates: []
			});
		}
		
		months.get(monthKey)!.dates.push(dateGroup);
	});
	
	return Array.from(months.values()).sort((a, b) => {
		if (a.year !== b.year) return b.year - a.year;
		return b.month - a.month;
	});
}

const commits = await getCommitHistory();
const dateGroups = groupCommitsByDate(commits);
const monthGroups = groupByMonth(dateGroups);

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	"@id": `${Astro.site}diff`,
	name: "更新日志",
	description: "UpXuu 博客的更新历史记录",
	url: `${Astro.site}diff`,
	author: {
		"@type": "Person",
		name: profileConfig.name,
	},
	inLanguage: siteConfig.lang.replace("_", "-"),
};
---

<MainGridLayout title="更新日志" description="UpXuu 博客的更新历史记录">
	<BannerTitle slot="banner-title"></BannerTitle>
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
	
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
			<div class="mb-10 text-center">
				<h1 class="text-4xl font-bold text-gray-800 dark:text-gray-200 mb-3">
					📝 更新日志
				</h1>
				<p class="text-gray-600 dark:text-gray-400">
					记录博客的每一次更新与改进
				</p>
			</div>
			
			<div class="month-navigation mb-8 flex flex-wrap gap-2 justify-center">
				{monthGroups.map((month) => (
					<a
						href={`#month-${month.year}-${month.month}`}
						class="px-3 py-1 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-full text-sm hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors"
					>
						{month.formattedMonth}
					</a>
				))}
			</div>
			
			<div class="commit-timeline">
				{monthGroups.map((month) => (
					<div id={`month-${month.year}-${month.month}`} class="mb-8">
						<h2 class="text-xl font-bold text-gray-700 dark:text-gray-300 mb-4 sticky top-20 bg-[var(--content-bg)] py-2 z-10">
							{month.formattedMonth}
						</h2>
						
						<div class="space-y-4">
							{month.dates.map((dateGroup, dateIndex) => (
								<div class="date-group">
									<button
										onclick={`toggleDateGroup('date-${dateIndex}-${month.year}-${month.month}')`}
										class="w-full text-left mb-2"
									>
										<div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200">
											<svg 
												xmlns="http://www.w3.org/2000/svg" 
												class="h-4 w-4 transition-transform"
												id={`arrow-date-${dateIndex}-${month.year}-${month.month}`}
												viewBox="0 0 20 20" 
												fill="currentColor"
											>
												<path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
											</svg>
											<span class="font-medium">{dateGroup.formattedDate}</span>
											<span class="text-xs">({dateGroup.commits.length} 个提交)</span>
										</div>
									</button>
									
									<div 
										id={`date-${dateIndex}-${month.year}-${month.month}`}
										class="ml-6 space-y-3"
									>
										{dateGroup.commits.map((commit) => (
											<div class="commit-item relative pl-6 pb-2">
												<div class="absolute left-0 top-3 w-3 h-3 rounded-full bg-blue-400 border-2 border-white dark:border-gray-800"></div>
												
												<div class="bg-white dark:bg-gray-800/50 rounded-lg p-3 shadow-sm hover:shadow-md transition-shadow">
													<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-2">
														<div class="flex items-center gap-2 flex-wrap">
															<a 
																href={`https://github.com/ImUpXuu/myblog/commit/${commit.sha}`}
																target="_blank"
																rel="noopener noreferrer"
																class="text-sm font-mono text-blue-600 dark:text-blue-400 hover:underline"
															>
																{commit.shortSha}
															</a>
															<span class="text-xs text-gray-500 dark:text-gray-400">
																{formatDate(commit.date)}
															</span>
														</div>
														<span class="text-xs text-gray-500 dark:text-gray-400">
															by {commit.author}
														</span>
													</div>
													
													<p class="text-gray-700 dark:text-gray-300 text-sm mb-2">
														{commit.message}
													</p>
													
													{commit.files.length > 0 && (
														<div class="mt-2 pt-2 border-t border-gray-200 dark:border-gray-700">
															<div class="flex flex-wrap gap-1">
																{commit.files.map((file) => (
																	<span 
																		class={`inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs ${
																			file.status === 'added' 
																				? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400' 
																				: file.status === 'removed'
																				? 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400'
																				: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400'
																		}`}
																		title={`${file.additions} 行添加，${file.deletions} 行删除`}
																	>
																		{file.status === 'added' ? '+' : file.status === 'removed' ? '-' : 'M'}
																		{file.filename.split('/').pop()}
																		{file.additions > 0 && (
																			<span class="text-xs opacity-75">+{file.additions}</span>
																		)}
																	</span>
																))}
															</div>
														</div>
													)}
												</div>
											</div>
										))}
									</div>
								</div>
							))}
						</div>
					</div>
				))}
			</div>
			
			{commits.length === 0 && (
				<div class="text-center py-12">
					<p class="text-gray-500 dark:text-gray-400">
						暂无更新记录
					</p>
				</div>
			)}
		</div>
	</div>
</MainGridLayout>

<script>
	function toggleDateGroup(dateId: string) {
		const element = document.getElementById(dateId);
		const arrow = document.getElementById(`arrow-${dateId}`);
		
		if (element && arrow) {
			const isCollapsed = element.style.display === 'none';
			
			if (isCollapsed) {
				element.style.display = 'block';
				arrow.style.transform = 'rotate(0deg)';
			} else {
				element.style.display = 'none';
				arrow.style.transform = 'rotate(-90deg)';
			}
		}
	}
	
	document.addEventListener('DOMContentLoaded', () => {
		const dateGroups = document.querySelectorAll('[id^="date-"]');
		dateGroups.forEach((group) => {
			const groupId = group.id;
			const parts = groupId.split('-');
			const dateIndex = parts[1];
			const year = parts[2];
			const month = parts[3];
			
			if (dateIndex !== '0') {
				group.style.display = 'none';
				const arrow = document.getElementById(`arrow-${groupId}`);
				if (arrow) {
					arrow.style.transform = 'rotate(-90deg)';
				}
			}
		});
	});
</script>

<style>
.commit-timeline {
	animation: fadeIn 0.5s ease-out;
}

.date-group {
	margin-bottom: 1rem;
}

@keyframes fadeIn {
	from {
		opacity: 0;
		transform: translateY(10px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}
</style>
