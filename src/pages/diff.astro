---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import BannerTitle from "../components/BannerTitle.astro";
import { profileConfig, siteConfig } from "../config";

interface CommitFile {
	filename: string;
	status: 'added' | 'removed' | 'modified' | 'renamed' | 'copied' | 'changed';
	additions: number;
	deletions: number;
	changes: number;
}

interface Commit {
	sha: string;
	shortSha: string;
	date: string;
	message: string;
	author: string;
	files: CommitFile[];
}

async function getCommitHistory(): Promise<Commit[]> {
	try {
		const response = await fetch('https://api.github.com/repos/ImUpXuu/myblog/commits?per_page=100', {
			headers: {
				'Accept': 'application/vnd.github.v3+json',
			},
			next: { revalidate: 300 }
		});

		if (!response.ok) {
			throw new Error('Failed to fetch commit history');
		}

		const commits = await response.json();
		
		const commitsWithFiles = await Promise.all(
			commits.map(async (commit: any) => {
				try {
					const detailResponse = await fetch(commit.url, {
						headers: {
							'Accept': 'application/vnd.github.v3+json',
						},
						next: { revalidate: 300 }
					});
					
					if (!detailResponse.ok) {
						return {
							sha: commit.sha,
							shortSha: commit.sha.substring(0, 7),
							date: commit.commit.author.date,
							message: commit.commit.message,
							author: commit.commit.author.name,
							files: []
						};
					}
					
					const detailData = await detailResponse.json();
					const files = detailData.files?.map((file: any) => ({
						filename: file.filename,
						status: file.status,
						additions: file.additions,
						deletions: file.deletions,
						changes: file.changes
					})) || [];
					
					return {
						sha: commit.sha,
						shortSha: commit.sha.substring(0, 7),
						date: commit.commit.author.date,
						message: commit.commit.message,
						author: commit.commit.author.name,
						files: files
					};
				} catch (error) {
					console.error(`Error fetching files for commit ${commit.sha}:`, error);
					return {
						sha: commit.sha,
						shortSha: commit.sha.substring(0, 7),
						date: commit.commit.author.date,
						message: commit.commit.message,
						author: commit.commit.author.name,
						files: []
					};
				}
			})
		);
		
		return commitsWithFiles;
	} catch (error) {
		console.error('Error fetching commit history:', error);
		return [];
	}
}

function formatDate(dateString: string): string {
	const date = new Date(dateString);
	date.setHours(date.getHours() + 8);
	const year = date.getFullYear();
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	const hour = String(date.getHours()).padStart(2, '0');
	const minute = String(date.getMinutes()).padStart(2, '0');
	
	return `${year}-${month}-${day} ${hour}:${minute}`;
}

const commits = await getCommitHistory();

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	"@id": `${Astro.site}diff`,
	name: "更新日志",
	description: "UpXuu 博客的更新历史记录",
	url: `${Astro.site}diff`,
	author: {
		"@type": "Person",
		name: profileConfig.name,
	},
	inLanguage: siteConfig.lang.replace("_", "-"),
};
---

<MainGridLayout title="更新日志" description="UpXuu 博客的更新历史记录">
	<BannerTitle slot="banner-title"></BannerTitle>
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
	
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
			<div class="mb-10 text-center">
				<h1 class="text-4xl font-bold text-gray-800 dark:text-gray-200 mb-3">
					📝 更新日志
				</h1>
				<p class="text-gray-600 dark:text-gray-400">
					记录博客的每一次更新与改进
				</p>
			</div>
			
			<div class="commit-timeline relative">
				{commits.map((commit, index) => (
					<div class="commit-item relative pl-8 pb-8 last:pb-0">
						{index !== commits.length - 1 && (
							<div class="absolute left-3 top-8 bottom-0 w-0.5 bg-gradient-to-b from-blue-300 to-blue-100 dark:from-blue-700 dark:to-blue-900"></div>
						)}
						<div class="absolute left-0 top-2 w-6 h-6 rounded-full bg-blue-500 border-4 border-white dark:border-gray-800 shadow-md"></div>
						
						<div class="bg-white dark:bg-gray-800/50 rounded-lg p-4 shadow-sm hover:shadow-md transition-shadow">
							<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-2">
								<div class="flex items-center gap-2 flex-wrap">
									<a 
										href={`https://github.com/ImUpXuu/myblog/commit/${commit.sha}`}
										target="_blank"
										rel="noopener noreferrer"
										class="text-sm font-mono text-blue-600 dark:text-blue-400 hover:underline"
									>
										{commit.shortSha}
									</a>
									<span class="text-xs text-gray-500 dark:text-gray-400">
										{formatDate(commit.date)}
									</span>
								</div>
								<span class="text-xs text-gray-500 dark:text-gray-400">
									by {commit.author}
								</span>
							</div>
							<p class="text-gray-700 dark:text-gray-300 text-sm mb-3">
								{commit.message}
							</p>
							
							{commit.files.length > 0 && (
								<div class="border-t border-gray-200 dark:border-gray-700 pt-3 mt-3">
									<div class="flex flex-wrap gap-2 mb-2">
										{commit.files.filter(f => f.status === 'added').length > 0 && (
											<span class="inline-flex items-center gap-1 px-2 py-1 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 text-xs rounded">
												<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
												</svg>
												+{commit.files.filter(f => f.status === 'added').length}
											</span>
										)}
										{commit.files.filter(f => f.status === 'modified').length > 0 && (
											<span class="inline-flex items-center gap-1 px-2 py-1 bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400 text-xs rounded">
												<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
												</svg>
												~{commit.files.filter(f => f.status === 'modified').length}
											</span>
										)}
										{commit.files.filter(f => f.status === 'removed').length > 0 && (
											<span class="inline-flex items-center gap-1 px-2 py-1 bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 text-xs rounded">
												<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path>
												</svg>
												-{commit.files.filter(f => f.status === 'removed').length}
											</span>
										)}
									</div>
									<div class="space-y-1 max-h-40 overflow-y-auto">
										{commit.files.map((file) => (
											<div class="flex items-center justify-between text-xs py-1 px-2 hover:bg-gray-100 dark:hover:bg-gray-700/50 rounded">
												<span class="font-mono text-gray-600 dark:text-gray-400 truncate flex-1">
													{file.filename}
												</span>
												<div class="flex items-center gap-2 ml-2 flex-shrink-0">
													{file.status === 'added' && (
														<span class="text-green-600 dark:text-green-400 font-medium">+{file.additions}</span>
													)}
													{file.status === 'modified' && (
														<span class="text-yellow-600 dark:text-yellow-400 font-medium">+{file.additions} -{file.deletions}</span>
													)}
													{file.status === 'removed' && (
														<span class="text-red-600 dark:text-red-400 font-medium">-{file.deletions}</span>
													)}
												</div>
											</div>
										))}
									</div>
								</div>
							)}
						</div>
					</div>
				))}
			</div>
			
			{commits.length === 0 && (
				<div class="text-center py-12">
					<p class="text-gray-500 dark:text-gray-400">
						暂无更新记录
					</p>
				</div>
			)}
		</div>
	</div>
</MainGridLayout>

<style>
.commit-timeline {
	animation: fadeIn 0.5s ease-out;
}

.commit-item:last-child {
	padding-bottom: 0;
}

@keyframes fadeIn {
	from {
		opacity: 0;
		transform: translateY(10px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}
</style>
