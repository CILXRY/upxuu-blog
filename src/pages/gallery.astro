---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import BannerTitle from "../components/BannerTitle.astro";
import { profileConfig, siteConfig } from "../config";

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	"@id": `${Astro.site}gallery`,
	name: "画廊",
	description: "UpXuu 的图片画廊",
	url: `${Astro.site}gallery`,
	author: {
		"@type": "Person",
		name: profileConfig.name,
	},
	inLanguage: siteConfig.lang.replace("_", "-"),
};
---

<MainGridLayout title="画廊" description="记录美好瞬间">
	<BannerTitle slot="banner-title"></BannerTitle>
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
	
	<div class="w-full max-w-7xl mx-auto px-6 py-10">
		<!-- 标题区域 -->
		<div class="text-center mb-12">
			<h1 class="text-4xl font-bold text-gray-800 dark:text-gray-200 mb-3">
				📷 画廊
			</h1>
			<p class="text-gray-600 dark:text-gray-400 text-lg">
				记录美好瞬间
			</p>
		</div>

		<!-- 刷新提示 -->
		<div id="refresh-notice" class="hidden mb-8 p-5 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-2xl text-center">
			<p class="text-blue-700 dark:text-blue-300 mb-4 text-base">
				👋 画廊需要刷新页面才能加载
			</p>
			<button onclick="window.location.reload()" class="px-8 py-3 bg-blue-500 hover:bg-blue-600 text-white rounded-xl font-medium transition-colors text-base">
				🔄 刷新页面
			</button>
		</div>

		<!-- 统计信息 -->
		<div class="flex justify-center gap-8 mb-10 text-base text-gray-600 dark:text-gray-400">
			<div class="flex items-center gap-3">
				<span class="text-xl">📁</span>
				<span class="text-base"><strong id="totalMonths">0</strong> 个月份</span>
			</div>
			<div class="flex items-center gap-3">
				<span class="text-xl">🖼️</span>
				<span class="text-base"><strong id="totalImages">0</strong> 张图片</span>
			</div>
		</div>

		<!-- 画廊网格 - 使用瀑布流布局 -->
		<div class="gallery grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4" id="gallery">
			<div class="loading-spinner col-span-full flex justify-center items-center py-20">
				<div class="relative">
					<div class="w-16 h-16 border-4 border-gray-200 dark:border-gray-700 rounded-full animate-spin border-t-blue-500"></div>
				</div>
			</div>
		</div>

		<!-- 错误提示 -->
		<div class="error-message hidden col-span-full flex justify-center items-center py-20">
			<div class="text-center text-red-500 p-8 bg-red-50 dark:bg-red-900/20 rounded-2xl">
				<p class="text-xl font-semibold mb-3">😢 加载失败</p>
				<p id="error-text" class="text-base"></p>
			</div>
		</div>

		<!-- 月份筛选（移动端显示） -->
		<div class="month-bar flex flex-wrap justify-center gap-3 mb-8" id="monthButtons"></div>
	</div>
</MainGridLayout>

<!-- 灯箱 - 自定义灯箱 -->
<div id="lightbox" class="fixed inset-0 bg-black/90 backdrop-blur-sm z-[9999] hidden">
	<button id="lightboxClose" class="absolute top-4 right-4 text-white text-4xl hover:text-gray-300 transition-colors z-10 p-2">×</button>
	
	<button id="lightboxPrev" class="absolute left-2 md:left-4 top-1/2 -translate-y-1/2 text-white text-2xl md:text-3xl hover:text-gray-300 transition-colors bg-black/30 hover:bg-black/50 rounded-full p-2 md:p-3">
		<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
		</svg>
	</button>
	
	<button id="lightboxNext" class="absolute right-2 md:right-4 top-1/2 -translate-y-1/2 text-white text-2xl md:text-3xl hover:text-gray-300 transition-colors bg-black/30 hover:bg-black/50 rounded-full p-2 md:p-3">
		<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
		</svg>
	</button>

	<div class="absolute inset-0 flex items-center justify-center p-4 md:p-8">
		<div class="relative max-w-full max-h-full">
			<img id="lightboxImg" src="" alt="" class="max-w-full max-h-[85vh] object-contain rounded-lg shadow-2xl">
			<div id="lightboxLoader" class="absolute inset-0 flex items-center justify-center">
				<div class="w-12 h-12 border-4 border-gray-600 border-t-white rounded-full animate-spin"></div>
			</div>
		</div>
	</div>

	<div class="absolute bottom-4 md:bottom-8 left-1/2 -translate-x-1/2 text-center text-white bg-black/60 backdrop-blur-sm px-4 md:px-6 py-2 md:py-3 rounded-lg max-w-[90%] md:max-w-none">
		<h3 id="lightbox-name" class="text-sm md:text-base font-semibold mb-1"></h3>
		<p id="lightbox-meta" class="text-xs md:text-sm text-gray-300"></p>
	</div>
</div>

<script>
	const API_BASE = 'https://edit.upxuu.com/api/images';
	let allMonths = [];
	let loadedMonths = {}; // 存储已加载的月份数据
	let currentImages = [];
	let currentImageIndex = 0;
	let isLoading = false;

	async function fetchJSON(url) {
		try {
			const response = await fetch(url);
			if (!response.ok) {
				throw new Error(`HTTP error! status: ${response.status}`);
			}
			return await response.json();
		} catch (error) {
			console.error('Fetch error:', error);
			throw error;
		}
	}

	function formatFileSize(bytes) {
		if (bytes === 0) return '0 B';
		const k = 1024;
		const sizes = ['B', 'KB', 'MB', 'GB'];
		const i = Math.floor(Math.log(bytes) / Math.log(k));
		return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
	}

	function formatDate(dateStr) {
		if (!dateStr) return '';
		const date = new Date(dateStr);
		return date.toLocaleDateString('zh-CN', {
			year: 'numeric',
			month: 'short',
			day: 'numeric'
		});
	}

	function showLoading() {
		const gallery = document.getElementById('gallery');
		gallery.innerHTML = `
			<div class="loading-spinner col-span-full flex justify-center items-center py-20">
				<div class="relative">
					<div class="w-12 h-12 border-4 border-gray-200 dark:border-gray-700 rounded-full animate-spin border-t-blue-500"></div>
				</div>
			</div>
		`;
		document.querySelector('.error-message').classList.add('hidden');
	}

	function showError(message) {
		const gallery = document.getElementById('gallery');
		gallery.innerHTML = '';
		document.querySelector('.error-message').classList.remove('hidden');
		document.getElementById('error-text').textContent = message;
	}

	function showRefreshNotice() {
		document.getElementById('refresh-notice').classList.remove('hidden');
		document.getElementById('gallery').innerHTML = '';
		document.getElementById('monthButtons').innerHTML = '';
	}

	// 获取所有月份列表
	async function loadMonthsList() {
		showLoading();

		try {
			// 先尝试加载当前月份
			const now = new Date();
			const currentMonth = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;
			
			// 从当前月份往前加载 12 个月
			const monthsToTry = [];
			for (let i = 0; i < 12; i++) {
				const date = new Date(now.getFullYear(), now.getMonth() - i, 1);
				const monthStr = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
				monthsToTry.push(monthStr);
			}

			// 并发请求所有月份
			const promises = monthsToTry.map(async (monthStr) => {
				try {
					const data = await fetchJSON(`${API_BASE}/${monthStr}`);
					return { month: monthStr, data: data, hasData: data.length > 0 };
				} catch (e) {
					return { month: monthStr, data: [], hasData: false };
				}
			});

			const results = await Promise.all(promises);
			
			// 过滤出有数据的月份，并按时间从新到旧排序
			allMonths = results
				.filter(r => r.hasData)
				.sort((a, b) => b.month.localeCompare(a.month)) // 从新到旧排序
				.map(r => ({
					month: r.month,
					count: r.data.length,
					displayName: r.month.replace('-', '年') + '月'
				}));

			if (allMonths.length > 0) {
				updateStats();
				renderMonthButtons();
				// 加载第一个月的数据
				await loadMonth(allMonths[0].month);
			} else {
				showError('暂无数据');
			}
		} catch (error) {
			console.error('Load months error:', error);
			showError(error.message);
		}
	}

	function updateStats() {
		document.getElementById('totalMonths').textContent = allMonths.length;
		const totalImages = allMonths.reduce((sum, month) => sum + month.count, 0);
		document.getElementById('totalImages').textContent = totalImages;
	}

	function renderMonthButtons() {
		const container = document.getElementById('monthButtons');
		container.innerHTML = '';

		allMonths.forEach((monthInfo, index) => {
			const btn = document.createElement('button');
			btn.className = 'month-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-blue-100 dark:hover:bg-blue-900/30 hover:text-blue-600 dark:hover:text-blue-400' + (index === 0 ? ' active bg-blue-500 text-white hover:bg-blue-600 dark:hover:bg-blue-600' : '');
			btn.textContent = `${monthInfo.displayName} (${monthInfo.count})`;
			btn.onclick = () => loadMonth(monthInfo.month, btn);
			container.appendChild(btn);
		});
	}

	async function loadMonth(monthStr, clickedBtn) {
		if (isLoading) return;
		
		showLoading();
		isLoading = true;

		// 更新月份按钮激活状态
		if (clickedBtn) {
			document.querySelectorAll('.month-btn').forEach(btn => {
				btn.classList.remove('active', 'bg-blue-500', 'text-white', 'hover:bg-blue-600', 'dark:hover:bg-blue-600');
				btn.classList.add('bg-gray-100', 'dark:bg-gray-800', 'text-gray-700', 'dark:text-gray-300');
			});
			clickedBtn.classList.remove('bg-gray-100', 'dark:bg-gray-800', 'text-gray-700', 'dark:text-gray-300', 'hover:bg-blue-100', 'dark:hover:bg-blue-900/30');
			clickedBtn.classList.add('active', 'bg-blue-500', 'text-white', 'hover:bg-blue-600', 'dark:hover:bg-blue-600');
		}

		try {
			// 如果已经加载过这个月，直接使用缓存
			if (loadedMonths[monthStr]) {
				// 按时间从新到旧排序（优先使用 created_at，包含具体时间）
				currentImages = [...loadedMonths[monthStr]].sort((a, b) => {
					const dateA = new Date(b.created_at || b.upload_date);
					const dateB = new Date(b.created_at || b.upload_date);
					return dateA.getTime() - dateB.getTime();
				});
				currentImageIndex = 0;
				renderGallery(currentImages);
			} else {
				// 加载新月份
				const data = await fetchJSON(`${API_BASE}/${monthStr}`);
				// 按时间从新到旧排序（优先使用 created_at，包含具体时间）
				loadedMonths[monthStr] = data.sort((a, b) => {
					const dateA = new Date(b.created_at || b.upload_date);
					const dateB = new Date(b.created_at || b.upload_date);
					return dateA.getTime() - dateB.getTime();
				});
				currentImages = loadedMonths[monthStr];
				currentImageIndex = 0;
				renderGallery(currentImages);
			}
		} catch (error) {
			showError(error.message);
		} finally {
			isLoading = false;
		}
	}

	function renderGallery(images) {
		const gallery = document.getElementById('gallery');
		
		if (!images || images.length === 0) {
			gallery.innerHTML = `
				<div class="col-span-full flex justify-center items-center py-20 text-gray-500 dark:text-gray-400">
					<div class="text-center">
						<p class="text-4xl mb-4">📭</p>
						<p class="text-lg">暂无图片</p>
					</div>
				</div>
			`;
			return;
		}

		gallery.innerHTML = '';
		
		images.forEach((image, index) => {
		const item = document.createElement('div');
		item.className = 'gallery-item group relative bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 cursor-pointer transform hover:scale-[1.02]';
		item.onclick = () => openLightbox(index);

		item.innerHTML = `
			<div class="overflow-hidden bg-gray-100 dark:bg-gray-700 aspect-[4/3]">
				<img 
					data-src="${image.url}" 
					alt="${image.name}" 
					loading="lazy"
					class="lazy-image w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 opacity-0"
					onerror="this.parentElement.parentElement.innerHTML='<div class=\\'w-full h-full flex items-center justify-center bg-gray-200 dark:bg-gray-600 text-gray-400 dark:text-gray-500\\'><span class=\\'text-5xl\\'>🖼️</span></div>'"
				>
			</div>
			<div class="gallery-item-info absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-5">
				<div class="text-white transform translate-y-3 group-hover:translate-y-0 transition-transform duration-300">
					<div class="gallery-item-name text-base font-semibold mb-2 truncate">${image.name}</div>
					<div class="gallery-item-meta text-sm text-gray-200 flex items-center gap-3">
						<span>${formatDate(image.upload_date || image.created_at)}</span>
						<span>•</span>
						<span>${formatFileSize(image.size)}</span>
					</div>
				</div>
			</div>
		`;

		gallery.appendChild(item);
	});

	// 初始化懒加载
	initLazyLoading();
}

function initLazyLoading() {
	const lazyImages = document.querySelectorAll('.lazy-image');
	
	// 控制并发数
	let loadingCount = 0;
	const maxConcurrent = 6;
	const queue = [];

	const imageObserver = new IntersectionObserver((entries, observer) => {
		// 按 DOM 顺序加载（已经是瀑布流顺序）
		entries.forEach(entry => {
			if (!entry.isIntersecting) return;

			const img = entry.target;
			const src = img.getAttribute('data-src');
			
			if (!src || queue.includes(img)) return;

			queue.push(img);
			tryLoadImage(img, observer);
		});
	}, {
		rootMargin: '100px 0px',
		threshold: 0.01
	});

	function tryLoadImage(img, observer) {
		if (loadingCount >= maxConcurrent) return;

		const src = img.getAttribute('data-src');
		if (!src) return;

		loadingCount++;
		
		const tempImg = new Image();
		tempImg.onload = () => {
			img.src = src;
			img.removeAttribute('data-src');
			img.classList.remove('opacity-0');
			observer.unobserve(img);
			loadingCount--;
			
			const index = queue.indexOf(img);
			if (index > -1) queue.splice(index, 1);
			
			processQueue(observer);
		};
		tempImg.onerror = () => {
			loadingCount--;
			const index = queue.indexOf(img);
			if (index > -1) queue.splice(index, 1);
			processQueue(observer);
		};
		tempImg.src = src;
	}

	function processQueue(observer) {
		if (loadingCount >= maxConcurrent || queue.length === 0) return;
		
		const nextImg = queue[0];
		if (nextImg) {
			tryLoadImage(nextImg, observer);
		}
	}

	lazyImages.forEach(img => imageObserver.observe(img));
}

	function openLightbox(index) {
		const lightbox = document.getElementById('lightbox');
		const lightboxImg = document.getElementById('lightboxImg');
		const loader = document.getElementById('lightboxLoader');
		const nameEl = document.getElementById('lightbox-name');
		const metaEl = document.getElementById('lightbox-meta');

		currentImageIndex = index;
		const image = currentImages[index];

		nameEl.textContent = image.name;
		metaEl.textContent = `${formatDate(image.upload_date || image.created_at)} · ${formatFileSize(image.size)}`;
		
		loader.classList.remove('hidden');
		lightboxImg.style.opacity = '0';
		
		const tempImg = new Image();
		tempImg.src = image.url;
		tempImg.onload = () => {
			lightboxImg.src = image.url;
			lightboxImg.style.opacity = '1';
			loader.classList.add('hidden');
		};

		lightbox.classList.remove('hidden');
		lightbox.classList.add('flex');
		document.body.style.overflow = 'hidden';

		updateNavButtons();
	}

	function closeLightbox() {
		const lightbox = document.getElementById('lightbox');
		lightbox.classList.remove('flex');
		lightbox.classList.add('hidden');
		document.body.style.overflow = '';
	}

	function navigateImage(direction) {
		let newIndex = currentImageIndex + direction;
		if (newIndex < 0) newIndex = currentImages.length - 1;
		if (newIndex >= currentImages.length) newIndex = 0;
		openLightbox(newIndex);
	}

	function updateNavButtons() {
		const prevBtn = document.getElementById('lightboxPrev');
		const nextBtn = document.getElementById('lightboxNext');
		if (currentImages.length <= 1) {
			prevBtn.classList.add('hidden');
			nextBtn.classList.add('hidden');
		} else {
			prevBtn.classList.remove('hidden');
			nextBtn.classList.remove('hidden');
		}
	}

	// 绑定灯箱按钮事件
	document.getElementById('lightboxClose').addEventListener('click', closeLightbox);
	document.getElementById('lightboxPrev').addEventListener('click', () => navigateImage(-1));
	document.getElementById('lightboxNext').addEventListener('click', () => navigateImage(1));

	// 点击背景关闭
	document.getElementById('lightbox').addEventListener('click', (e) => {
		if (e.target.id === 'lightbox' || e.target.classList.contains('relative')) {
			closeLightbox();
		}
	});

	document.addEventListener('keydown', (e) => {
		const lightbox = document.getElementById('lightbox');
		if (!lightbox.classList.contains('hidden')) {
			if (e.key === 'Escape') {
				closeLightbox();
			} else if (e.key === 'ArrowLeft') {
				navigateImage(-1);
			} else if (e.key === 'ArrowRight') {
				navigateImage(1);
			}
		}
	});

	// 页面加载完成后初始化
	if (document.readyState === 'complete') {
		loadMonthsList();
	} else {
		window.addEventListener('load', loadMonthsList);
	}
</script>

<style>
	.month-bar {
		max-width: 100%;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}

	.month-bar::-webkit-scrollbar {
		height: 6px;
	}

	.month-bar::-webkit-scrollbar-track {
		background: rgba(0, 0, 0, 0.05);
		border-radius: 3px;
	}

	.month-bar::-webkit-scrollbar-thumb {
		background: rgba(0, 0, 0, 0.2);
		border-radius: 3px;
	}

	.month-bar::-webkit-scrollbar-thumb:hover {
		background: rgba(0, 0, 0, 0.3);
	}

	.timeline-container::-webkit-scrollbar {
		width: 4px;
	}

	.timeline-container::-webkit-scrollbar-track {
		background: transparent;
	}

	.timeline-container::-webkit-scrollbar-thumb {
		background: rgba(0, 0, 0, 0.2);
		border-radius: 2px;
	}

	.timeline-container::-webkit-scrollbar-thumb:hover {
		background: rgba(0, 0, 0, 0.3);
	}

	@keyframes spin {
		to {
			transform: rotate(360deg);
		}
	}

	.animate-spin {
		animation: spin 1s linear infinite;
	}
</style>
