---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import BannerTitle from "../components/BannerTitle.astro";
import { profileConfig, siteConfig } from "../config";

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	"@id": `${Astro.site}gallery`,
	name: "画廊",
	description: "UpXuu 的图片画廊",
	url: `${Astro.site}gallery`,
	author: {
		"@type": "Person",
		name: profileConfig.name,
	},
	inLanguage: siteConfig.lang.replace("_", "-"),
};
---

<MainGridLayout title="画廊" description="记录美好瞬间">
	<BannerTitle slot="banner-title"></BannerTitle>
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
	
	<div class="w-full max-w-5xl mx-auto px-4 py-8">
		<!-- 标题区域 -->
		<div class="text-center mb-8">
			<h1 class="text-3xl font-bold text-gray-800 dark:text-gray-200 mb-2">
				📷 画廊
			</h1>
			<p class="text-gray-600 dark:text-gray-400">
				记录美好瞬间
			</p>
		</div>

		<!-- 刷新提示 -->
		<div id="refresh-notice" class="hidden mb-6 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-xl text-center">
			<p class="text-blue-700 dark:text-blue-300 mb-3">
				👋 画廊需要刷新页面才能加载
			</p>
			<button onclick="window.location.reload()" class="px-6 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-lg font-medium transition-colors">
				🔄 刷新页面
			</button>
		</div>

		<!-- 统计信息 -->
		<div class="flex justify-center gap-6 mb-6 text-sm text-gray-600 dark:text-gray-400">
			<div class="flex items-center gap-2">
				<span>📁</span>
				<span><strong id="totalMonths">0</strong> 个月份</span>
			</div>
			<div class="flex items-center gap-2">
				<span>🖼️</span>
				<span><strong id="totalImages">0</strong> 张图片</span>
			</div>
		</div>

		<!-- 月份筛选 -->
		<div class="month-bar flex flex-wrap justify-center gap-2 mb-6" id="monthButtons"></div>

		<!-- 画廊网格 -->
		<div class="gallery grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4" id="gallery">
			<div class="loading-spinner col-span-full flex justify-center items-center py-20">
				<div class="relative">
					<div class="w-12 h-12 border-4 border-gray-200 dark:border-gray-700 rounded-full animate-spin border-t-blue-500"></div>
				</div>
			</div>
		</div>

		<!-- 错误提示 -->
		<div class="error-message hidden col-span-full flex justify-center items-center py-20">
			<div class="text-center text-red-500 p-6 bg-red-50 dark:bg-red-900/20 rounded-xl">
				<p class="text-lg font-semibold mb-2">😢 加载失败</p>
				<p id="error-text" class="text-sm"></p>
			</div>
		</div>
	</div>
</MainGridLayout>

<!-- 灯箱 - 移到 MainGridLayout 外面以覆盖整个页面 -->
	<div id="lightbox" class="fixed inset-0 bg-black/90 backdrop-blur-sm z-[9999] hidden">
		<button id="lightbox-close" class="absolute top-4 right-4 text-white text-4xl hover:text-gray-300 transition-colors z-10 p-2">×</button>
		
		<button id="lightbox-prev" class="absolute left-2 md:left-4 top-1/2 -translate-y-1/2 text-white text-2xl md:text-3xl hover:text-gray-300 transition-colors bg-black/30 hover:bg-black/50 rounded-full p-2 md:p-3">
			<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
			</svg>
		</button>
		
		<button id="lightbox-next" class="absolute right-2 md:right-4 top-1/2 -translate-y-1/2 text-white text-2xl md:text-3xl hover:text-gray-300 transition-colors bg-black/30 hover:bg-black/50 rounded-full p-2 md:p-3">
			<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
			</svg>
		</button>

		<div class="absolute inset-0 flex items-center justify-center p-4 md:p-8">
			<div class="relative max-w-full max-h-full">
				<img id="lightboxImg" src="" alt="" class="max-w-full max-h-[85vh] object-contain rounded-lg shadow-2xl">
				<div id="lightboxLoader" class="absolute inset-0 flex items-center justify-center">
					<div class="w-12 h-12 border-4 border-gray-600 border-t-white rounded-full animate-spin"></div>
				</div>
			</div>
		</div>

		<div class="absolute bottom-4 md:bottom-8 left-1/2 -translate-x-1/2 text-center text-white bg-black/60 backdrop-blur-sm px-4 md:px-6 py-2 md:py-3 rounded-lg max-w-[90%] md:max-w-none">
			<h3 id="lightbox-name" class="text-sm md:text-base font-semibold mb-1"></h3>
			<p id="lightbox-meta" class="text-xs md:text-sm text-gray-300"></p>
		</div>
	</div>

<script>
	const BASE_URL = 'https://edit.upxuu.com/img';
	let allMonths = [];
	let currentImages = [];
	let currentImageIndex = 0;
	let isLoaded = false;

	async function fetchJSON(url) {
		try {
			const response = await fetch(url);
			if (!response.ok) {
				throw new Error(`HTTP error! status: ${response.status}`);
			}
			return await response.json();
		} catch (error) {
			console.error('Fetch error:', error);
			throw error;
		}
	}

	function formatFileSize(bytes) {
		if (bytes === 0) return '0 B';
		const k = 1024;
		const sizes = ['B', 'KB', 'MB', 'GB'];
		const i = Math.floor(Math.log(bytes) / Math.log(k));
		return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
	}

	function formatDate(dateStr) {
		if (!dateStr) return '';
		const date = new Date(dateStr);
		return date.toLocaleDateString('zh-CN', {
			year: 'numeric',
			month: 'short',
			day: 'numeric'
		});
	}

	function showLoading() {
		const gallery = document.getElementById('gallery');
		gallery.innerHTML = `
			<div class="loading-spinner col-span-full flex justify-center items-center py-20">
				<div class="relative">
					<div class="w-12 h-12 border-4 border-gray-200 dark:border-gray-700 rounded-full animate-spin border-t-blue-500"></div>
				</div>
			</div>
		`;
		document.querySelector('.error-message').classList.add('hidden');
	}

	function showError(message) {
		const gallery = document.getElementById('gallery');
		gallery.innerHTML = '';
		document.querySelector('.error-message').classList.remove('hidden');
		document.getElementById('error-text').textContent = message;
	}

	function showRefreshNotice() {
		document.getElementById('refresh-notice').classList.remove('hidden');
		document.getElementById('gallery').innerHTML = '';
		document.getElementById('monthButtons').innerHTML = '';
	}

	async function loadRootIndex() {
		if (isLoaded) return;
		
		showLoading();

		try {
			const rootIndex = await fetchJSON(`${BASE_URL}/index.json`);
			allMonths = rootIndex.months || [];
			
			updateStats();
			renderMonthButtons();
			
			if (allMonths.length > 0) {
				await loadMonth(allMonths[0].index);
				isLoaded = true;
			} else {
				showError('暂无数据');
			}
		} catch (error) {
			console.error('Gallery load error:', error);
			showRefreshNotice();
		}
	}

	function updateStats() {
		document.getElementById('totalMonths').textContent = allMonths.length;
		const totalImages = allMonths.reduce((sum, month) => sum + (month.count || 0), 0);
		document.getElementById('totalImages').textContent = totalImages;
	}

	function renderMonthButtons() {
		const container = document.getElementById('monthButtons');
		container.innerHTML = '';

		allMonths.forEach((month, index) => {
			const btn = document.createElement('button');
			btn.className = 'month-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-blue-100 dark:hover:bg-blue-900/30 hover:text-blue-600 dark:hover:text-blue-400' + (index === 0 ? ' active bg-blue-500 text-white hover:bg-blue-600 dark:hover:bg-blue-600' : '');
			btn.textContent = `${month.ym} (${month.count || 0})`;
			btn.onclick = () => loadMonth(month.index, btn);
			container.appendChild(btn);
		});
	}

	async function loadMonth(monthIndexUrl, clickedBtn) {
		showLoading();

		if (clickedBtn) {
			document.querySelectorAll('.month-btn').forEach(btn => {
				btn.classList.remove('active', 'bg-blue-500', 'text-white', 'hover:bg-blue-600', 'dark:hover:bg-blue-600');
				btn.classList.add('bg-gray-100', 'dark:bg-gray-800', 'text-gray-700', 'dark:text-gray-300');
			});
			clickedBtn.classList.remove('bg-gray-100', 'dark:bg-gray-800', 'text-gray-700', 'dark:text-gray-300', 'hover:bg-blue-100', 'dark:hover:bg-blue-900/30');
			clickedBtn.classList.add('active', 'bg-blue-500', 'text-white', 'hover:bg-blue-600', 'dark:hover:bg-blue-600');
		}

		try {
			const monthData = await fetchJSON(monthIndexUrl);
			currentImages = monthData.images || [];
			currentImageIndex = 0;
			renderGallery(currentImages);
		} catch (error) {
			showError(error.message);
		}
	}

	function renderGallery(images) {
		const gallery = document.getElementById('gallery');
		
		if (!images || images.length === 0) {
			gallery.innerHTML = `
				<div class="col-span-full flex justify-center items-center py-20 text-gray-500 dark:text-gray-400">
					<div class="text-center">
						<p class="text-4xl mb-4">📭</p>
						<p class="text-lg">暂无图片</p>
					</div>
				</div>
			`;
			return;
		}

		gallery.innerHTML = '';
		
		images.forEach((image, index) => {
			const item = document.createElement('div');
			item.className = 'gallery-item group relative bg-white dark:bg-gray-800 rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 cursor-pointer transform hover:scale-105';
			item.onclick = () => openLightbox(index);

			item.innerHTML = `
				<div class="aspect-square overflow-hidden bg-gray-100 dark:bg-gray-700">
					<img 
						src="${image.url}" 
						alt="${image.name}" 
						loading="lazy"
						class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
						onerror="this.parentElement.parentElement.innerHTML='<div class=\\'aspect-square flex items-center justify-center bg-gray-200 dark:bg-gray-600 text-gray-400 dark:text-gray-500\\'><span class=\\'text-4xl\\'>🖼️</span></div>'"
					>
				</div>
				<div class="gallery-item-info absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-4">
					<div class="text-white transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
						<div class="gallery-item-name text-sm font-semibold mb-1 truncate">${image.name}</div>
						<div class="gallery-item-meta text-xs text-gray-200 flex items-center gap-2">
							<span>${formatDate(image.date)}</span>
							<span>•</span>
							<span>${formatFileSize(image.size)}</span>
						</div>
					</div>
				</div>
			`;

			gallery.appendChild(item);
		});
	}

	function openLightbox(index) {
		const lightbox = document.getElementById('lightbox');
		const lightboxImg = document.getElementById('lightboxImg');
		const loader = document.getElementById('lightboxLoader');
		const nameEl = document.getElementById('lightbox-name');
		const metaEl = document.getElementById('lightbox-meta');

		currentImageIndex = index;
		const image = currentImages[index];

		nameEl.textContent = image.name;
		metaEl.textContent = `${formatDate(image.date)} · ${formatFileSize(image.size)}`;
		
		loader.classList.remove('hidden');
		lightboxImg.style.opacity = '0';
		
		const tempImg = new Image();
		tempImg.src = image.url;
		tempImg.onload = () => {
			lightboxImg.src = image.url;
			lightboxImg.style.opacity = '1';
			loader.classList.add('hidden');
		};

		lightbox.classList.remove('hidden');
		lightbox.classList.add('flex');
		document.body.style.overflow = 'hidden';

		updateNavButtons();
	}

	function closeLightbox() {
		const lightbox = document.getElementById('lightbox');
		lightbox.classList.remove('flex');
		lightbox.classList.add('hidden');
		document.body.style.overflow = '';
	}

	function navigateImage(direction) {
		let newIndex = currentImageIndex + direction;
		if (newIndex < 0) newIndex = currentImages.length - 1;
		if (newIndex >= currentImages.length) newIndex = 0;
		openLightbox(newIndex);
	}

	function updateNavButtons() {
		const prevBtn = document.getElementById('lightbox-prev');
		const nextBtn = document.getElementById('lightbox-next');
		if (currentImages.length <= 1) {
			prevBtn.classList.add('hidden');
			nextBtn.classList.add('hidden');
		} else {
			prevBtn.classList.remove('hidden');
			nextBtn.classList.remove('hidden');
		}
	}

	// 绑定灯箱按钮事件
	document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
	document.getElementById('lightbox-prev').addEventListener('click', () => navigateImage(-1));
	document.getElementById('lightbox-next').addEventListener('click', () => navigateImage(1));

	// 灯箱背景点击关闭
	document.getElementById('lightbox').addEventListener('click', (e) => {
		if (e.target.id === 'lightbox') {
			closeLightbox();
		}
	});

	document.addEventListener('keydown', (e) => {
		const lightbox = document.getElementById('lightbox');
		if (!lightbox.classList.contains('hidden')) {
			if (e.key === 'Escape') {
				closeLightbox();
			} else if (e.key === 'ArrowLeft') {
				navigateImage(-1);
			} else if (e.key === 'ArrowRight') {
				navigateImage(1);
			}
		}
	});

	// 初始化：总是显示刷新按钮，让用户手动点击
	function initGallery() {
		showRefreshNotice();
	}

	// 页面加载完成后初始化
	if (document.readyState === 'complete') {
		initGallery();
	} else {
		window.addEventListener('load', initGallery);
	}
</script>

<style>
	.month-bar {
		max-width: 100%;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}

	.month-bar::-webkit-scrollbar {
		height: 6px;
	}

	.month-bar::-webkit-scrollbar-track {
		background: rgba(0, 0, 0, 0.05);
		border-radius: 3px;
	}

	.month-bar::-webkit-scrollbar-thumb {
		background: rgba(0, 0, 0, 0.2);
		border-radius: 3px;
	}

	.month-bar::-webkit-scrollbar-thumb:hover {
		background: rgba(0, 0, 0, 0.3);
	}

	@keyframes spin {
		to {
			transform: rotate(360deg);
		}
	}

	.animate-spin {
		animation: spin 1s linear infinite;
	}
</style>
