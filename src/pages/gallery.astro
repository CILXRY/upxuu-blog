---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import BannerTitle from "../components/BannerTitle.astro";
import { profileConfig, siteConfig } from "../config";
import PhotoSwipeLightbox from "photoswipe/lightbox";
import PhotoSwipe from "photoswipe";

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	"@id": `${Astro.site}gallery`,
	name: "画廊",
	description: "UpXuu 的图片画廊",
	url: `${Astro.site}gallery`,
	author: {
		"@type": "Person",
		name: profileConfig.name,
	},
	inLanguage: siteConfig.lang.replace("_", "-"),
};
---

<MainGridLayout title="画廊" description="记录美好瞬间">
	<BannerTitle slot="banner-title"></BannerTitle>
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
	
	<div class="w-full max-w-5xl mx-auto px-4 py-8">
		<!-- 标题区域 -->
		<div class="text-center mb-8">
			<h1 class="text-3xl font-bold text-gray-800 dark:text-gray-200 mb-2">
				📷 画廊
			</h1>
			<p class="text-gray-600 dark:text-gray-400">
				记录美好瞬间
			</p>
		</div>

		<!-- 刷新提示 -->
		<div id="refresh-notice" class="hidden mb-6 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-xl text-center">
			<p class="text-blue-700 dark:text-blue-300 mb-3">
				👋 画廊需要刷新页面才能加载
			</p>
			<button onclick="window.location.reload()" class="px-6 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-lg font-medium transition-colors">
				🔄 刷新页面
			</button>
		</div>

		<!-- 统计信息 -->
		<div class="flex justify-center gap-6 mb-6 text-sm text-gray-600 dark:text-gray-400">
			<div class="flex items-center gap-2">
				<span>📁</span>
				<span><strong id="totalMonths">0</strong> 个月份</span>
			</div>
			<div class="flex items-center gap-2">
				<span>🖼️</span>
				<span><strong id="totalImages">0</strong> 张图片</span>
			</div>
		</div>

		<!-- 月份筛选 -->
		<div class="month-bar flex flex-wrap justify-center gap-2 mb-6" id="monthButtons"></div>

		<!-- 画廊网格 - 使用瀑布流布局 -->
		<div class="gallery columns-2 md:columns-3 lg:columns-4 gap-3 md:gap-4 space-y-3 md:space-y-4" id="gallery">
			<div class="loading-spinner col-span-full flex justify-center items-center py-20">
				<div class="relative">
					<div class="w-12 h-12 border-4 border-gray-200 dark:border-gray-700 rounded-full animate-spin border-t-blue-500"></div>
				</div>
			</div>
		</div>

		<!-- 错误提示 -->
		<div class="error-message hidden col-span-full flex justify-center items-center py-20">
			<div class="text-center text-red-500 p-6 bg-red-50 dark:bg-red-900/20 rounded-xl">
				<p class="text-lg font-semibold mb-2">😢 加载失败</p>
				<p id="error-text" class="text-sm"></p>
			</div>
		</div>
	</div>
</MainGridLayout>

<!-- 灯箱 - 使用 PhotoSwipe -->
<div class="pswp" tabindex="-1" role="dialog" aria-hidden="true">
	<div class="pswp__bg"></div>
	
	<div class="pswp__scroll-wrap">
		<div class="pswp__container">
			<div class="pswp__item"></div>
			<div class="pswp__item"></div>
			<div class="pswp__item"></div>
		</div>
		
		<div class="pswp__ui pswp__ui--hidden">
			<div class="pswp__top-bar">
				<div class="pswp__counter"></div>
				<button class="pswp__button pswp__button--close" title="关闭 (Esc)"></button>
				<button class="pswp__button pswp__button--zoom" title="缩放"></button>
				<div class="pswp__preloader">
					<div class="pswp__preloader__icn">
						<div class="pswp__preloader__cut">
							<div class="pswp__preloader__donut"></div>
						</div>
					</div>
				</div>
			</div>
			<div class="pswp__share-modal pswp__share-modal--hidden pswp__single-tap">
				<div class="pswp__share-tooltip"></div>
			</div>
			<button class="pswp__button pswp__button--arrow--left" title="上一张"></button>
			<button class="pswp__button pswp__button--arrow--right" title="下一张"></button>
			<div class="pswp__caption">
				<div class="pswp__caption__center"></div>
			</div>
		</div>
	</div>
</div>

<script>
	const API_BASE = 'https://edit.upxuu.com/api/images';
	let allMonths = [];
	let loadedMonths = {}; // 存储已加载的月份数据
	let currentImages = [];
	let currentImageIndex = 0;
	let isLoading = false;

	async function fetchJSON(url) {
		try {
			const response = await fetch(url);
			if (!response.ok) {
				throw new Error(`HTTP error! status: ${response.status}`);
			}
			return await response.json();
		} catch (error) {
			console.error('Fetch error:', error);
			throw error;
		}
	}

	function formatFileSize(bytes) {
		if (bytes === 0) return '0 B';
		const k = 1024;
		const sizes = ['B', 'KB', 'MB', 'GB'];
		const i = Math.floor(Math.log(bytes) / Math.log(k));
		return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
	}

	function formatDate(dateStr) {
		if (!dateStr) return '';
		const date = new Date(dateStr);
		return date.toLocaleDateString('zh-CN', {
			year: 'numeric',
			month: 'short',
			day: 'numeric'
		});
	}

	function showLoading() {
		const gallery = document.getElementById('gallery');
		gallery.innerHTML = `
			<div class="loading-spinner col-span-full flex justify-center items-center py-20">
				<div class="relative">
					<div class="w-12 h-12 border-4 border-gray-200 dark:border-gray-700 rounded-full animate-spin border-t-blue-500"></div>
				</div>
			</div>
		`;
		document.querySelector('.error-message').classList.add('hidden');
	}

	function showError(message) {
		const gallery = document.getElementById('gallery');
		gallery.innerHTML = '';
		document.querySelector('.error-message').classList.remove('hidden');
		document.getElementById('error-text').textContent = message;
	}

	function showRefreshNotice() {
		document.getElementById('refresh-notice').classList.remove('hidden');
		document.getElementById('gallery').innerHTML = '';
		document.getElementById('monthButtons').innerHTML = '';
	}

	// 获取所有月份列表
	async function loadMonthsList() {
		showLoading();

		try {
			// 先尝试加载当前月份
			const now = new Date();
			const currentMonth = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;
			
			// 从当前月份往前加载 12 个月
			const monthsToTry = [];
			for (let i = 0; i < 12; i++) {
				const date = new Date(now.getFullYear(), now.getMonth() - i, 1);
				const monthStr = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
				monthsToTry.push(monthStr);
			}

			// 并发请求所有月份
			const promises = monthsToTry.map(async (monthStr) => {
				try {
					const data = await fetchJSON(`${API_BASE}/${monthStr}`);
					return { month: monthStr, data: data, hasData: data.length > 0 };
				} catch (e) {
					return { month: monthStr, data: [], hasData: false };
				}
			});

			const results = await Promise.all(promises);
			
			// 过滤出有数据的月份，并按时间从新到旧排序
			allMonths = results
				.filter(r => r.hasData)
				.sort((a, b) => b.month.localeCompare(a.month)) // 从新到旧排序
				.map(r => ({
					month: r.month,
					count: r.data.length,
					displayName: r.month.replace('-', '年') + '月'
				}));

			if (allMonths.length > 0) {
				updateStats();
				renderMonthButtons();
				// 加载第一个月的数据
				await loadMonth(allMonths[0].month);
			} else {
				showError('暂无数据');
			}
		} catch (error) {
			console.error('Load months error:', error);
			showError(error.message);
		}
	}

	function updateStats() {
		document.getElementById('totalMonths').textContent = allMonths.length;
		const totalImages = allMonths.reduce((sum, month) => sum + month.count, 0);
		document.getElementById('totalImages').textContent = totalImages;
	}

	function renderMonthButtons() {
		const container = document.getElementById('monthButtons');
		container.innerHTML = '';

		allMonths.forEach((monthInfo, index) => {
			const btn = document.createElement('button');
			btn.className = 'month-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-blue-100 dark:hover:bg-blue-900/30 hover:text-blue-600 dark:hover:text-blue-400' + (index === 0 ? ' active bg-blue-500 text-white hover:bg-blue-600 dark:hover:bg-blue-600' : '');
			btn.textContent = `${monthInfo.displayName} (${monthInfo.count})`;
			btn.onclick = () => loadMonth(monthInfo.month, btn);
			container.appendChild(btn);
		});
	}

	async function loadMonth(monthStr, clickedBtn) {
		if (isLoading) return;
		
		showLoading();
		isLoading = true;

		if (clickedBtn) {
			document.querySelectorAll('.month-btn').forEach(btn => {
				btn.classList.remove('active', 'bg-blue-500', 'text-white', 'hover:bg-blue-600', 'dark:hover:bg-blue-600');
				btn.classList.add('bg-gray-100', 'dark:bg-gray-800', 'text-gray-700', 'dark:text-gray-300');
			});
			clickedBtn.classList.remove('bg-gray-100', 'dark:bg-gray-800', 'text-gray-700', 'dark:text-gray-300', 'hover:bg-blue-100', 'dark:hover:bg-blue-900/30');
			clickedBtn.classList.add('active', 'bg-blue-500', 'text-white', 'hover:bg-blue-600', 'dark:hover:bg-blue-600');
		}

		try {
			// 如果已经加载过这个月，直接使用缓存
			if (loadedMonths[monthStr]) {
				// 按时间从新到旧排序（优先使用 created_at，包含具体时间）
				currentImages = [...loadedMonths[monthStr]].sort((a, b) => {
					const dateA = new Date(b.created_at || b.upload_date);
					const dateB = new Date(b.created_at || b.upload_date);
					return dateA.getTime() - dateB.getTime();
				});
				currentImageIndex = 0;
				renderGallery(currentImages);
			} else {
				// 加载新月份
				const data = await fetchJSON(`${API_BASE}/${monthStr}`);
				// 按时间从新到旧排序（优先使用 created_at，包含具体时间）
				loadedMonths[monthStr] = data.sort((a, b) => {
					const dateA = new Date(b.created_at || b.upload_date);
					const dateB = new Date(b.created_at || b.upload_date);
					return dateA.getTime() - dateB.getTime();
				});
				currentImages = loadedMonths[monthStr];
				currentImageIndex = 0;
				renderGallery(currentImages);
			}
		} catch (error) {
			showError(error.message);
		} finally {
			isLoading = false;
		}
	}

	function renderGallery(images) {
		const gallery = document.getElementById('gallery');
		
		if (!images || images.length === 0) {
			gallery.innerHTML = `
				<div class="col-span-full flex justify-center items-center py-20 text-gray-500 dark:text-gray-400">
					<div class="text-center">
						<p class="text-4xl mb-4">📭</p>
						<p class="text-lg">暂无图片</p>
					</div>
				</div>
			`;
			return;
		}

		gallery.innerHTML = '';
		
		images.forEach((image, index) => {
			const item = document.createElement('div');
			item.className = 'gallery-item group relative bg-white dark:bg-gray-800 rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 cursor-pointer transform hover:scale-105 break-inside-avoid mb-3 md:mb-4';
			item.onclick = () => openLightbox(index);

			item.innerHTML = `
				<div class="overflow-hidden bg-gray-100 dark:bg-gray-700">
					<img 
						src="${image.url}" 
						alt="${image.name}" 
						loading="lazy"
						class="w-full h-auto object-cover transition-transform duration-300 group-hover:scale-110"
						onerror="this.parentElement.parentElement.innerHTML='<div class=\\'w-full h-48 flex items-center justify-center bg-gray-200 dark:bg-gray-600 text-gray-400 dark:text-gray-500\\'><span class=\\'text-4xl\\'>🖼️</span></div>'"
					>
				</div>
				<div class="gallery-item-info absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-4">
					<div class="text-white transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
						<div class="gallery-item-name text-sm font-semibold mb-1 truncate">${image.name}</div>
						<div class="gallery-item-meta text-xs text-gray-200 flex items-center gap-2">
							<span>${formatDate(image.upload_date || image.created_at)}</span>
							<span>•</span>
							<span>${formatFileSize(image.size)}</span>
						</div>
					</div>
				</div>
			`;

			gallery.appendChild(item);
		});
	}

	function openLightbox(index) {
		// 使用 PhotoSwipe 打开灯箱
		const items = currentImages.map((image) => ({
			src: image.url,
			w: image.width || 1920,
			h: image.height || 1080,
			title: `${image.name}<br><small>${formatDate(image.upload_date || image.created_at)} · ${formatFileSize(image.size)}</small>`
		}));

		const pswpElement = document.querySelector('.pswp');
		const options = {
			index: index,
			history: false,
			focus: true,
			showHideOpacity: true,
			getThumbBoundsFn: (index) => {
				const thumbnail = document.querySelectorAll('.gallery-item img')[index];
				if (!thumbnail) return undefined;
				const pageYScroll = window.pageYOffset || document.documentElement.scrollTop;
				const rect = thumbnail.getBoundingClientRect();
				return { x: rect.left, y: rect.top + pageYScroll, w: rect.width };
			}
		};

		const gallery = new PhotoSwipe(pswpElement, PhotoSwipeLightbox, items, options);
		gallery.init();
	}

	function closeLightbox() {
		// PhotoSwipe 会自动处理关闭
	}

	function navigateImage(direction) {
		// PhotoSwipe 会自动处理导航
	}

	function updateNavButtons() {
		// PhotoSwipe 会自动处理导航按钮
	}

	// PhotoSwipe 会自动处理所有事件，不需要手动绑定

	// 页面加载完成后初始化
	if (document.readyState === 'complete') {
		loadMonthsList();
	} else {
		window.addEventListener('load', loadMonthsList);
	}
</script>

<style>
	.month-bar {
		max-width: 100%;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}

	.month-bar::-webkit-scrollbar {
		height: 6px;
	}

	.month-bar::-webkit-scrollbar-track {
		background: rgba(0, 0, 0, 0.05);
		border-radius: 3px;
	}

	.month-bar::-webkit-scrollbar-thumb {
		background: rgba(0, 0, 0, 0.2);
		border-radius: 3px;
	}

	.month-bar::-webkit-scrollbar-thumb:hover {
		background: rgba(0, 0, 0, 0.3);
	}

	@keyframes spin {
		to {
			transform: rotate(360deg);
		}
	}

	.animate-spin {
		animation: spin 1s linear infinite;
	}
</style>
